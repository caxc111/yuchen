<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <!-- 图标资源字典 -->
    <!-- 使用方式: <StaticResource ResourceKey="IconFactory" /> -->
    
    <!-- 模块图标 -->
    <materialDesign:PackIcon x:Key="IconFactory" Kind="Factory" Width="20" Height="20" />
    <materialDesign:PackIcon x:Key="IconProduct" Kind="Package" Width="20" Height="20" />
    <materialDesign:PackIcon x:Key="IconBOM" Kind="Layers" Width="20" Height="20" />
    <materialDesign:PackIcon x:Key="IconPurchase" Kind="ShoppingCart" Width="20" Height="20" />
    <materialDesign:PackIcon x:Key="IconContract" Kind="FileText" Width="20" Height="20" />
    <materialDesign:PackIcon x:Key="IconReport" Kind="BarChart" Width="20" Height="20" />
    
    <!-- 操作图标 -->
    <materialDesign:PackIcon x:Key="IconAdd" Kind="Plus" Width="16" Height="16" />
    <materialDesign:PackIcon x:Key="IconEdit" Kind="Edit" Width="16" Height="16" />
    <materialDesign:PackIcon x:Key="IconDelete" Kind="Delete" Width="16" Height="16" />
    <materialDesign:PackIcon x:Key="IconView" Kind="Eye" Width="16" Height="16" />
    <materialDesign:PackIcon x:Key="IconSearch" Kind="Search" Width="16" Height="16" />
    
    <!-- 状态图标 -->
    <materialDesign:PackIcon x:Key="IconSuccess" Kind="CheckCircle" Width="16" Height="16" />
    <materialDesign:PackIcon x:Key="IconError" Kind="AlertCircle" Width="16" Height="16" />
    <materialDesign:PackIcon x:Key="IconWarning" Kind="AlertTriangle" Width="16" Height="16" />
    <materialDesign:PackIcon x:Key="IconInfo" Kind="Information" Width="16" Height="16" />

    <!-- 窗口按钮图标 -->
    <materialDesign:PackIcon x:Key="IconMinimize" Kind="WindowMinimize" Width="14" Height="14" />
    <materialDesign:PackIcon x:Key="IconMaximize" Kind="WindowMaximize" Width="14" Height="14" />
    <materialDesign:PackIcon x:Key="IconRestore" Kind="WindowRestore" Width="14" Height="14" />
    <materialDesign:PackIcon x:Key="IconClose" Kind="Close" Width="14" Height="14" />

</ResourceDictionary>