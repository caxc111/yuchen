<Window x:Class="FactoryProductManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:FactoryProductManager.Views"
        xmlns:converters="clr-namespace:FactoryProductManager.Converters"
        mc:Ignorable="d"
        Title="宇辰产品管理系统" Height="800" Width="1400" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/Icons/yuchenlogo.png">
    
    <Window.Resources>
        <Style x:Key="NavItemStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WarmHeaderBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Setter Property="BorderThickness" Value="{StaticResource UnifiedBorderThickness}"/>
            <Setter Property="CornerRadius" Value="{StaticResource UnifiedMediumCornerRadius}"/>
            <Setter Property="Margin" Value="4,6,4,0"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Image Source="Resources/Icons/factory_bg.jpeg" Stretch="Fill"/>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" ClipToBounds="False">
                <Border Margin="0,20,0,20" Padding="5" Background="Transparent" ClipToBounds="False">
                    <StackPanel ClipToBounds="False">
                        <Border Height="100" Margin="0,10,0,20" HorizontalAlignment="Center">
                            <StackPanel Orientation="Vertical">
                                <Image Source="Resources/Icons/yuchenlogo.png" Width="64" Height="64" Margin="0,10,0,5"/>
                                <TextBlock Text="宇辰产品管理系统" FontSize="14" HorizontalAlignment="Center" Foreground="#333333"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Tag="Factory" Style="{StaticResource NavItemStyle}"
                                Background="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PageToBackgroundConverter}, ConverterParameter=Factory}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" CommandParameter="Factory"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                <Image Source="Resources/Icons/icon_factory.png" Width="36" Height="36" Margin="0,0,14,0"/>
                                <TextBlock Text="工厂管理" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Tag="Material" Style="{StaticResource NavItemStyle}"
                                Background="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PageToBackgroundConverter}, ConverterParameter=Material}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" CommandParameter="Material"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                <Image Source="Resources/Icons/icon_product.png" Width="36" Height="36" Margin="0,0,14,0"/>
                                <TextBlock Text="物料管理" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                            </StackPanel>
                        </Border>

                        <Border Tag="ProductManagement" Style="{StaticResource NavItemStyle}"
                                Background="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PageToBackgroundConverter}, ConverterParameter=ProductManagement}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" CommandParameter="ProductManagement"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                <Image Source="Resources/Icons/icon_product_management.png" Width="36" Height="36" Margin="0,0,14,0"/>
                                <TextBlock Text="产品管理" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Tag="BOM" Style="{StaticResource NavItemStyle}"
                                Background="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PageToBackgroundConverter}, ConverterParameter=BOM}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" CommandParameter="BOM"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                <Image Source="Resources/Icons/icon_bom.png" Width="36" Height="36" Margin="0,0,14,0"/>
                                <TextBlock Text="BOM管理" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Tag="Purchase" Style="{StaticResource NavItemStyle}"
                                Background="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PageToBackgroundConverter}, ConverterParameter=Purchase}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" CommandParameter="Purchase"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                <Image Source="Resources/Icons/icon_purchase.png" Width="36" Height="36" Margin="0,0,14,0"/>
                                <TextBlock Text="采购管理" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Tag="Contract" Style="{StaticResource NavItemStyle}"
                                Background="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PageToBackgroundConverter}, ConverterParameter=Contract}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" CommandParameter="Contract"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                <Image Source="Resources/Icons/icon_contract.png" Width="36" Height="36" Margin="0,0,14,0"/>
                                <TextBlock Text="合同管理" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Tag="Report" Style="{StaticResource NavItemStyle}"
                                Background="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PageToBackgroundConverter}, ConverterParameter=Report}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" CommandParameter="Report"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                <Image Source="Resources/Icons/icon_report.png" Width="36" Height="36" Margin="0,0,14,0"/>
                                <TextBlock Text="报表统计" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Border Margin="20" CornerRadius="15" Background="Transparent">
                    <ContentControl Content="{Binding CurrentView}"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>