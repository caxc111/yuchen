<Window x:Class="FactoryProductManager.Views.FactoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="工厂信息" Height="550" Width="550"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="工厂编码" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.FactoryCode}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="工厂名称" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.FactoryName}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="工厂类型" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" SelectedValue="{Binding Factory.FactoryType}" SelectedValuePath="Content" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1">
                        <ComboBoxItem Content="柜体木饰面"/>
                        <ComboBoxItem Content="柜体、家具五金"/>
                        <ComboBoxItem Content="金属柜门"/>
                        <ComboBoxItem Content="瓷砖"/>
                        <ComboBoxItem Content="石材"/>
                        <ComboBoxItem Content="人造石"/>
                        <ComboBoxItem Content="户内门"/>
                        <ComboBoxItem Content="门窗五金"/>
                        <ComboBoxItem Content="卫浴陶瓷"/>
                        <ComboBoxItem Content="厨卫五金"/>
                        <ComboBoxItem Content="灯具开关"/>
                        <ComboBoxItem Content="电器"/>
                    </ComboBox>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="地址" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.Address}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="联系人" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.ContactPerson}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="联系信息" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.ContactInfo}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="认证情况" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.Certifications}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="工厂规模" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.Scale}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="员工人数" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.EmployeeCount}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="生产能力" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.ProductionCapacity}" Margin="10,10,10,0" Background="White" BorderBrush="Gray" BorderThickness="1"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="备注" Margin="0,10,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Factory.Description}" Margin="10,10,10,0" Height="60" Background="White" BorderBrush="Gray" BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="确定" Margin="0,0,10,0" Width="80" Click="OkButton_Click"
                    Background="#2196F3" Foreground="White" BorderBrush="#1976D2" BorderThickness="1"
                    Padding="5"/>
            <Button Content="取消" Width="80" Click="CancelButton_Click"
                    Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1"
                    Padding="5"/>
        </StackPanel>
    </Grid>
</Window>