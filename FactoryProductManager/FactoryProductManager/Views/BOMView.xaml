<UserControl x:Class="FactoryProductManager.Views.BOMView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Resources/Icons/icon_bom.png" Width="32" Height="32" Margin="0,0,10,0"/>
            <TextBlock Text="BOM管理" FontSize="24" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox Width="150" Background="White" BorderBrush="Gray" BorderThickness="1" Padding="5"/>
            <Button Content="添加组件" Margin="10,0" Background="#2196F3" Foreground="White" 
                    BorderBrush="#1976D2" BorderThickness="1" Padding="10,5"/>
            <Button Margin="10,0,0,0" Width="36" Height="36" 
                    Background="#4CAF50" Foreground="White" 
                    BorderBrush="#388E3C" BorderThickness="1">
                <TextBlock Text="+" FontSize="18"/>
            </Button>
        </StackPanel>

        <DataGrid Grid.Row="2" AutoGenerateColumns="False" 
                  BorderBrush="#CCCCCC" BorderThickness="1"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#CCCCCC"
                  VerticalGridLinesBrush="#CCCCCC"
                  ColumnHeaderHeight="35"
                  RowHeight="40">
            <DataGrid.Columns>
                <DataGridTextColumn Header="成品名称" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="组件编码" Binding="{Binding ComponentCode}" Width="*"/>
                <DataGridTextColumn Header="组件名称" Binding="{Binding ComponentName}" Width="*"/>
                <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="*"/>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="*"/>
                <DataGridTextColumn Header="单价" Binding="{Binding UnitPrice}" Width="*"/>
                <DataGridTextColumn Header="小计" Binding="{Binding Amount}" Width="*"/>
                <DataGridTemplateColumn Header="操作" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button ToolTip="编辑" Width="28" Height="28" Background="#FFC107" 
                                        BorderBrush="#FFA000" BorderThickness="1" Margin="0,0,5,0">
                                    <TextBlock Text="✎" FontSize="12"/>
                                </Button>
                                <Button ToolTip="删除" Width="28" Height="28" Background="#F44336" 
                                        BorderBrush="#D32F2F" BorderThickness="1">
                                    <TextBlock Text="✕" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>