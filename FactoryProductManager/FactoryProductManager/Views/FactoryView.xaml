<UserControl x:Class="FactoryProductManager.Views.FactoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Resources/Icons/icon_factory.png" Width="32" Height="32" Margin="0,0,10,0"/>
            <TextBlock Text="工厂管理" FontSize="24" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="SearchTextBox" Width="200" 
                     Background="White" BorderBrush="Gray" BorderThickness="1" 
                     Foreground="Black" Padding="5" 
                     ToolTip="搜索工厂名称..."/>
            <Button Content="搜索" Margin="10,0" Click="SearchButton_Click"
                    Background="#2196F3" Foreground="White" 
                    BorderBrush="#1976D2" BorderThickness="1"
                    Padding="10,5" MinWidth="70"/>
            <Button Content="添加工厂" Margin="10,0" Click="AddButton_Click"
                    Background="#4CAF50" Foreground="White" 
                    BorderBrush="#388E3C" BorderThickness="1"
                    Padding="10,5" MinWidth="90"/>
        </StackPanel>

        <DataGrid Grid.Row="2" AutoGenerateColumns="False" ItemsSource="{Binding Factories}"
                  BorderBrush="#CCCCCC" BorderThickness="1"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#CCCCCC"
                  VerticalGridLinesBrush="#CCCCCC"
                  ColumnHeaderHeight="35"
                  RowHeight="40"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="工厂编码" Binding="{Binding FactoryCode}" Width="*">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="工厂名称" Binding="{Binding FactoryName}" Width="*">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="类型" Binding="{Binding FactoryType}" Width="*">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="详细信息" Width="100">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center">
                                <ToggleButton x:Name="DetailsToggle" Content="展开" Width="60" Background="#81C784" Foreground="White" BorderThickness="1" BorderBrush="#43A047">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="5,2" CornerRadius="3">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup IsOpen="{Binding IsChecked, ElementName=DetailsToggle}" Placement="Bottom" StaysOpen="False" Width="500">
                                    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="15" CornerRadius="5">
                                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="工厂详细信息" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center" Foreground="#333333"/>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="工厂编码" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding FactoryCode}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="工厂名称" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding FactoryName}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="工厂类型" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding FactoryType}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="地址" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding Address}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="联系人" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding ContactPerson}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="联系信息" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding ContactInfo}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="联系方法" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding ContactMethod}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="认证情况" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding Certifications}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="工厂规模" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding Scale}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="员工人数" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding EmployeeCount}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="生产能力" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding ProductionCapacity}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="负责人" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                    <TextBlock Text="{Binding ControllingPerson}" Grid.Column="1" Foreground="#333333"/>
                                                </Grid>
                                                
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="备注" Grid.Column="0" FontWeight="Bold" Foreground="#666666" VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding Description}" Grid.Column="1" Foreground="#333333" TextWrapping="Wrap"/>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="操作" Width="100">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button ToolTip="编辑" Click="EditButton_Click" Tag="{Binding}" Margin="0,0,5,0"
                                        Width="28" Height="28" Background="#FFC107" 
                                        BorderBrush="#FFA000" BorderThickness="1">
                                    <TextBlock Text="✎" FontSize="12"/>
                                </Button>
                                <Button ToolTip="删除" Click="DeleteButton_Click" Tag="{Binding}"
                                        Width="28" Height="28" Background="#F44336" 
                                        BorderBrush="#D32F2F" BorderThickness="1">
                                    <TextBlock Text="✕" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>