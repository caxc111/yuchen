<Window x:Class="FactoryProductManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FactoryProductManager.Views"
        mc:Ignorable="d"
        Title="宇辰产品管理系统" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/Icons/yuchenlogo.png">
    
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧菜单 -->
        <Border Background="LightGray" Grid.Column="0">
            <StackPanel>
                <!-- Logo区域 -->
                <Border Height="80" Background="#2196F3" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="Resources/Icons/yuchenlogo.png" Width="40" Height="40" Margin="0,0,10,0"/>
                        <TextBlock Text="宇辰产品管理系统" Foreground="White" FontSize="16" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- 导航按钮 -->
                <Button Style="{StaticResource NavButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Factory">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Resources/Icons/icon_factory.png" Width="20" Height="20" Margin="0,0,10,0"/>
                        <TextBlock Text="工厂管理" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource NavButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Product">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Resources/Icons/icon_product.png" Width="20" Height="20" Margin="0,0,10,0"/>
                        <TextBlock Text="产品管理" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource NavButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="BOM">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Resources/Icons/icon_bom.png" Width="20" Height="20" Margin="0,0,10,0"/>
                        <TextBlock Text="BOM管理" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource NavButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Purchase">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Resources/Icons/icon_purchase.png" Width="20" Height="20" Margin="0,0,10,0"/>
                        <TextBlock Text="采购管理" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource NavButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Contract">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Resources/Icons/icon_contract.png" Width="20" Height="20" Margin="0,0,10,0"/>
                        <TextBlock Text="合同管理" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource NavButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Report">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Resources/Icons/icon_report.png" Width="20" Height="20" Margin="0,0,10,0"/>
                        <TextBlock Text="报表统计" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- 右侧内容区域 -->
        <Border Grid.Column="1" Background="White">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>