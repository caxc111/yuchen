<Window x:Class="FactoryProductManager.Views.MaterialSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FactoryProductManager.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="选择材料" Height="720" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Style="{StaticResource UnifiedDialogBorderStyle}">
        <Grid Background="Transparent"
              xmlns:local="clr-namespace:FactoryProductManager">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏（可拖拽） -->
            <Border Grid.Row="0" Background="{StaticResource WarmHeaderBrush}"
                    CornerRadius="12,12,0,0"
                    local:WindowDragBehavior.Enable="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" x:Name="TitleText" Text="选择材料"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"/>

                    <!-- 窗口按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="最小化">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="最大化">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="关闭">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 材料列表 -->
            <Border Grid.Row="1" Margin="0"
                    Background="{StaticResource WarmPanelBrush}"
                    CornerRadius="10"
                    BorderBrush="{StaticResource InputBorderBrush}"
                    BorderThickness="1">
                <DataGrid x:Name="MaterialsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Extended"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="{StaticResource WarmRowBrush}"
                          AlternatingRowBackground="{StaticResource WarmSurfaceBrush}"
                          RowHeight="42"
                          MinRowHeight="42"
                          PreviewMouseLeftButtonDown="MaterialsDataGrid_PreviewMouseLeftButtonDown"
                          HeadersVisibility="Column"
                          CanUserResizeRows="False"
                          SelectionUnit="Cell"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource WarmHeaderBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="8,10"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border x:Name="CheckBorder" Width="20" Height="20" CornerRadius="4"
                                                BorderBrush="{StaticResource HintTextBrush}" BorderThickness="2"
                                                Background="White"/>
                                        <TextBlock x:Name="CheckMark" Text="✔" FontSize="14" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="CheckBorder" Property="Background" Value="#2196F3"/>
                                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#2196F3"/>
                                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="物料名称" Binding="{Binding MaterialName}" Width="*" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="图纸编号" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Margin="0" Padding="4">
                                        <TextBlock Text="{Binding DrawingNumber}" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="规格" Binding="{Binding Specification}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="缩略图" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="ImageBorder" Width="70" Height="32" CornerRadius="4"
                                            Background="{StaticResource WarmPanelBrush}" Cursor="Hand"
                                            BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1"
                                            PreviewMouseLeftButtonDown="Thumbnail_Click" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid>
                                            <TextBlock Text="无图片" FontSize="9" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="{StaticResource HintTextBrush}"
                                                       Visibility="{Binding ImageUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <Image Source="{Binding ImageUrl}" Stretch="Uniform"
                                                   Visibility="{Binding ImageUrl, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="单价" Binding="{Binding CostPrice, StringFormat={}{0:F2}}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="4,0,8,0"/>
                                    <Setter Property="Foreground" Value="#E67E22"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="55">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="数量" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding QuantityDisplay, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             HorizontalContentAlignment="Right"
                                             VerticalContentAlignment="Center"
                                             Margin="4,0,8,0"
                                             Padding="4,0"
                                             BorderThickness="1"
                                             BorderBrush="{StaticResource InputBorderBrush}"
                                             PreviewTextInput="QuantityTextBox_PreviewTextInput"
                                             TextChanged="QuantityTextBox_TextChanged"
                                             GotFocus="QuantityTextBox_GotFocus"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="小计" Binding="{Binding Subtotal, StringFormat={}{0:F2}}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="4,0,8,0"/>
                                    <Setter Property="Foreground" Value="#E67E22"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,15,10,10">
                <Button Content="取消" Click="CancelButton_Click"
                        Width="90" Height="35" Margin="0,0,10,0"
                        Style="{StaticResource AddMaterialButtonStyle}"/>
                <Button x:Name="OkButton" Content="确认选择" Click="OkButton_Click"
                        Width="100" Height="35"
                        Style="{StaticResource AddMaterialButtonStyle}"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
