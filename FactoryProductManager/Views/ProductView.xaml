<UserControl x:Class="FactoryProductManager.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Margin="10,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <TextBlock Text="物料管理" FontSize="32" FontWeight="Bold" Foreground="#333333"/>
        </StackPanel>

        <!-- 搜索和添加区域 -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <!-- 背景层 -->
            <Border BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                </Border.Background>
            </Border>
            <!-- 内容层（清晰） -->
            <Border Background="Transparent" BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="400" Height="35">
                        <Border BorderBrush="White" BorderThickness="1.2" CornerRadius="10">
                            <Border.Background>
                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                            </Border.Background>
                        </Border>
                        <TextBox x:Name="SearchTextBox"
                                 Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                 Foreground="#333333" Padding="10" FontSize="14"
                                 ToolTip="搜索物料..."/>
                    </Grid>
                    <Border Width="80" Height="35" Margin="20,0,0,0" Cursor="Hand" CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                        <Grid Width="80" Height="35" ClipToBounds="False">
                            <Border Width="80" Height="35" CornerRadius="10" ClipToBounds="False">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <Border.Effect>
                                    <BlurEffect Radius="20"/>
                                </Border.Effect>
                            </Border>
                            <Button Content="搜索" Margin="0" Click="SearchButton_Click"
                                    Background="Transparent" Foreground="#2196F3"
                                    BorderBrush="Transparent" BorderThickness="0"
                                    FontSize="14" Cursor="Hand"/>
                        </Grid>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Cursor="Hand" CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                        <Grid Width="100" Height="35" ClipToBounds="False">
                            <Border Width="100" Height="35" CornerRadius="10" ClipToBounds="False">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <Border.Effect>
                                    <BlurEffect Radius="20"/>
                                </Border.Effect>
                            </Border>
                            <Button Content="添加物料" Margin="0" Click="AddButton_Click"
                                    Background="Transparent" Foreground="#4CAF50"
                                    BorderBrush="Transparent" BorderThickness="0"
                                    FontSize="14" Cursor="Hand"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 数据表格 -->
        <Grid Grid.Row="2" Margin="0,0,0,0">
            <!-- 边框层 -->
            <Border BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                </Border.Background>
                <DataGrid ItemsSource="{Binding Products}"
                          AutoGenerateColumns="False"
                          BorderBrush="Transparent"
                          GridLinesVisibility="None"
                          HorizontalGridLinesBrush="Transparent"
                          VerticalGridLinesBrush="Transparent"
                          ColumnHeaderHeight="35"
                          RowHeight="36"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="Transparent"
                          IsReadOnly="True"
                          Margin="0"
                          Padding="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工厂物料编码" Binding="{Binding FactoryProductCode}" Width="140">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="宇辰物料编码" Binding="{Binding MyProductCode}" Width="140">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="100">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="所属工厂" Binding="{Binding FactoryName}" Width="*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="类别" Binding="{Binding Category}" Width="180">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="缩略图" Width="80">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Width="50" Height="50" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image.Source>
                                            <Binding Path="ImageUrl" FallbackValue="/Resources/Icons/icon_no_image.png"/>
                                        </Image.Source>
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                        <Setter Property="Source" Value="/Resources/Icons/icon_no_image.png"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                        <Setter Property="Source" Value="/Resources/Icons/icon_no_image.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="详细信息" Width="100">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center">
                                        <ToggleButton x:Name="DetailsToggle" Width="28" Height="28"
                                                     Background="#F5F5F5" BorderBrush="#E0E0E0"
                                                     BorderThickness="1" Cursor="Hand">
                                            <Image Source="/Resources/Icons/icon_expand.png" Width="16" Height="16" Stretch="Uniform"/>
                                        </ToggleButton>
                                        <Popup IsOpen="{Binding IsChecked, ElementName=DetailsToggle}" Placement="Bottom" StaysOpen="False" Width="520">
                                            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="15" CornerRadius="8">
                                                <Border.Effect>
                                                    <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.3"/>
                                                </Border.Effect>
                                                <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                                                    <StackPanel>
                                                        <TextBlock Text="产品详细信息" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center" Foreground="#333333"/>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="工厂物料编码" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding FactoryProductCode}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="宇辰物料编码" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding MyProductCode}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="产品名称" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding ProductName}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="品牌" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding Brand}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="规格" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding Specification}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="纹理" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding Texture}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="工艺" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding Process}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="适用场景" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding UsageScenario}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="认证情况" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding Certifications}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="所属工厂" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding FactoryName}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="类别" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/>
                                                            <TextBlock Text="{Binding Category}" Grid.Column="1" Foreground="#333333"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="缩略图" Grid.Column="0" FontWeight="Bold" Foreground="#666666" VerticalAlignment="Top"/>
                                                            <Image Grid.Column="1" Width="120" Height="100" Stretch="Uniform">
                                                                <Image.Source>
                                                                    <Binding Path="ImageUrl" FallbackValue="/Resources/Icons/icon_no_image.png"/>
                                                                </Image.Source>
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                                                <Setter Property="Source" Value="/Resources/Icons/icon_no_image.png"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                                                <Setter Property="Source" Value="/Resources/Icons/icon_no_image.png"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                        </Grid>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="备注" Grid.Column="0" FontWeight="Bold" Foreground="#666666" VerticalAlignment="Top"/>
                                                            <TextBlock Text="{Binding Description}" Grid.Column="1" Foreground="#333333" TextWrapping="Wrap"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </Popup>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="操作" Width="130">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button ToolTip="编辑" Click="EditButton_Click" Tag="{Binding}" Margin="0,0,5,0"
                                                Width="28" Height="28" Background="#F5F5F5"
                                                BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Cursor="Hand">
                                            <Image Source="/Resources/Icons/icon_edit.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button ToolTip="删除" Click="DeleteButton_Click" Tag="{Binding}"
                                                Width="28" Height="28" Background="#F5F5F5"
                                                BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Cursor="Hand">
                                            <Image Source="/Resources/Icons/icon_delete.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridRow">
                                        <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False" Margin="2">
                                            <Grid ClipToBounds="False">
                                                <Border CornerRadius="10" ClipToBounds="False">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <BlurEffect Radius="20"/>
                                                    </Border.Effect>
                                                </Border>
                                                <DataGridCellsPresenter/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
