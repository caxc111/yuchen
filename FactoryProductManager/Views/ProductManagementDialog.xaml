<Window x:Class="FactoryProductManager.Views.ProductManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="产品信息" Height="430" Width="620"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.RowSpan="3" BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
                </Border.Effect>
                <Border.Background>
                    <SolidColorBrush Color="#FFF5E6D3" Opacity="0.7"/>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#333333"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="产品编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.ProductCode}" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="产品名称" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.ProductName}" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="规格" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.Specification}" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="单位" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.Unit}" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="总成本" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.TotalCost, UpdateSourceTrigger=LostFocus}" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="销售价" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.SellingPrice, TargetNullValue='', UpdateSourceTrigger=LostFocus}" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="是否启用" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <CheckBox Grid.Column="1" Margin="10,16,0,0" IsChecked="{Binding Product.IsActive}" VerticalAlignment="Center" Foreground="#333333" Content="启用"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Border Width="90" Height="35" Margin="0,0,15,0" Cursor="Hand" CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                            <Grid Width="90" Height="35" ClipToBounds="False">
                                <Border Width="90" Height="35" CornerRadius="10" ClipToBounds="False">
                                    <Border.Background>
                                        <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                    </Border.Background>
                                    <Border.Effect>
                                        <BlurEffect Radius="20"/>
                                    </Border.Effect>
                                </Border>
                                <Button Content="确定" Margin="0" Width="90" Height="35" Click="OkButton_Click"
                                        Background="Transparent" Foreground="#2196F3"
                                        BorderBrush="Transparent" BorderThickness="0"
                                        FontSize="14" Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <Border Width="90" Height="35" Cursor="Hand" CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                            <Grid Width="90" Height="35" ClipToBounds="False">
                                <Border Width="90" Height="35" CornerRadius="10" ClipToBounds="False">
                                    <Border.Background>
                                        <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                    </Border.Background>
                                    <Border.Effect>
                                        <BlurEffect Radius="20"/>
                                    </Border.Effect>
                                </Border>
                                <Button Content="取消" Width="90" Height="35" Click="CancelButton_Click"
                                        Background="Transparent" Foreground="#666666"
                                        BorderBrush="Transparent" BorderThickness="0"
                                        FontSize="14" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
