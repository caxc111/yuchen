<Window x:Class="FactoryProductManager.Views.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="产品信息" Height="650" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="AlignedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0,24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid>
                                <TextBlock x:Name="ContentSite"
                                           Margin="8,0,24,0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           FontSize="16"
                                           FontWeight="Medium"
                                           Foreground="#333333">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="SelectionBoxItem" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Path HorizontalAlignment="Right"
                                      Margin="0,0,10,0"
                                      VerticalAlignment="Center"
                                      Fill="#666666"
                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="220">
                                    <Border Background="White"
                                            BorderBrush="#CCCCCC"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.RowSpan="3" BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
                </Border.Effect>
                <Border.Background>
                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#333333"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <StackPanel>
                            <!-- 工厂物料编码 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="工厂物料编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.FactoryProductCode}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 宇辰物料编码 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="宇辰物料编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.MyProductCode}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 产品名称 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="产品名称" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.ProductName}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 品牌 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="品牌" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.Brand}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 规格 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="规格" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.Specification}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 纹理 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="纹理" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.Texture}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 工艺 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="工艺" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.Process}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 适用场景 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="适用场景" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.UsageScenario}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 认证情况 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="认证情况" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.Certifications}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 所属工厂 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="所属工厂" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Product.FactoryName}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <!-- 类别 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 标签 -->
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="类别" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- 三个下拉固定存在，宽度388=126*3+8间距 -->
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="35">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="126"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="126"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 一级 -->
                                    <Border Grid.Column="0" Width="126" Height="38" BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                        <ComboBox x:Name="CategoryLevel1"
                                                  Style="{StaticResource AlignedComboBoxStyle}"
                                                  FontSize="16"
                                                  SelectionChanged="CategoryLevel1_SelectionChanged">
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="FontSize" Value="16"/>
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                    <Setter Property="Foreground" Value="#333333"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                        </ComboBox>
                                    </Border>

                                    <!-- 二级 -->
                                    <Border Grid.Column="2" x:Name="Level2Border" Width="126" Height="38" BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                        <ComboBox x:Name="CategoryLevel2"
                                                  Style="{StaticResource AlignedComboBoxStyle}"
                                                  FontSize="16"
                                                  SelectionChanged="CategoryLevel2_SelectionChanged">
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="FontSize" Value="16"/>
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                    <Setter Property="Foreground" Value="#333333"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                        </ComboBox>
                                    </Border>

                                    <!-- 三级 -->
                                    <Border Grid.Column="4" x:Name="Level3Border" Width="128" Height="38" BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4" Visibility="Collapsed">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                        <ComboBox x:Name="CategoryLevel3"
                                                  Style="{StaticResource AlignedComboBoxStyle}"
                                                  FontSize="16">
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="FontSize" Value="16"/>
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                    <Setter Property="Foreground" Value="#333333"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                        </ComboBox>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- 缩略图 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="缩略图" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="388" Height="150">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4" Background="#F5F5F5">
                                        <Border.Effect>
                                            <BlurEffect Radius="10"/>
                                        </Border.Effect>
                                    </Border>
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4" Background="Transparent"
                                            AllowDrop="True" DragOver="ImageDropZone_DragOver"
                                            Drop="ImageDropZone_Drop" MouseLeftButtonUp="ImageDropZone_Click"
                                            Cursor="Hand">
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image x:Name="PreviewImage" Width="120" Height="100" Stretch="Uniform" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="ImageHintText" Text="拖拽图片到此处或点击选择"
                                                       FontSize="12" Foreground="#999999" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="确定" Margin="0,0,15,0" Width="90" Height="35" Click="OkButton_Click"
                                Background="#2196F3" Foreground="White"
                                BorderBrush="#1976D2" BorderThickness="1"
                                Padding="5" FontSize="14"/>
                        <Button Content="取消" Width="90" Height="35" Click="CancelButton_Click"
                                Background="#F5F5F5" Foreground="#333333"
                                BorderBrush="#E0E0E0" BorderThickness="1"
                                Padding="5" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
