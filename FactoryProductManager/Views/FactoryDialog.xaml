<Window x:Class="FactoryProductManager.Views.FactoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="工厂信息" Height="550" Width="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="UnifiedDialogLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>
        <Style x:Key="UnifiedDialogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- 内容层 -->
        <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource WarmPanelBorderStyle}" Padding="15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>
                        <!-- 工厂编码 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="工厂编码" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.FactoryCode}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 工厂名称 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="工厂名称" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.FactoryName}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 品牌 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="品牌" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Column="1" Margin="10,10,0,0" Width="380">
                                <Grid Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox Text="{Binding Factory.Brand}"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                                <TextBlock Text="多个品牌请用 / 分隔"
                                           Margin="4,4,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource HintTextBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- 工厂类型（下拉框） -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="工厂类型" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <ComboBox SelectedItem="{Binding Factory.FactoryType}" Name="FactoryTypeComboBox"
                                          Style="{StaticResource WarmInputComboBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 地址 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="地址" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.Address}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 联系人 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="联系人" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.ContactPerson}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 联系信息 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="联系信息" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.ContactInfo}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 认证情况 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="认证情况" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.Certifications}"
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 工厂规模 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="工厂规模" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.Scale}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 员工人数 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="员工人数" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.EmployeeCount, TargetNullValue='', UpdateSourceTrigger=LostFocus}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- 生产能力 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="生产能力" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="35">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.ProductionCapacity}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}"/>
                            </Grid>
                        </Grid>
                        
                        <!-- 备注 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="备注" Margin="0,10,0,0" VerticalAlignment="Top" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <Grid Grid.Column="1" Margin="10,10,0,0" Width="380" Height="80">
                                <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                </Border>
                                <TextBox Text="{Binding Factory.Description}" 
                                         Style="{StaticResource WarmInputTextBoxStyle}" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Border Width="90" Height="35" Margin="0,0,15,0" Style="{StaticResource WarmActionBorderStyle}">
                                <Button Content="确定" Width="90" Height="35" Click="OkButton_Click"
                                        Style="{StaticResource UnifiedDialogActionButtonStyle}"/>
                    </Border>
                    <Border Width="90" Height="35" Style="{StaticResource WarmActionBorderStyle}">
                        <Button Content="取消" Width="90" Height="35" Click="CancelButton_Click"
                                Style="{StaticResource UnifiedDialogActionButtonStyle}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
