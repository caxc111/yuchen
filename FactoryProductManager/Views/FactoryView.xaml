<UserControl x:Class="FactoryProductManager.Views.FactoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <Style x:Key="UnifiedToolbarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Resources/Icons/icon_factory.png" Width="32" Height="32" Margin="0,0,10,0"/>
            <TextBlock Text="工厂管理" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Border Style="{StaticResource WarmPanelBorderStyle}" Padding="10"/>
            <Border Background="Transparent" BorderThickness="0" CornerRadius="10" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="400" Height="35">
                        <TextBox x:Name="SearchTextBox"
                                 Style="{StaticResource WarmSearchTextBoxStyle}"
                                 Foreground="{StaticResource PrimaryTextBrush}" Padding="10,0" FontSize="14"
                                 HorizontalAlignment="Stretch"
                                 VerticalContentAlignment="Center"
                                 ToolTip="搜索工厂名称..."/>
                    </Grid>
                    <Border Width="80" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SearchCommand}"/>
                        </Border.InputBindings>
                        <Button Content="搜索" Margin="0" Click="SearchButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding AddCommand}"/>
                        </Border.InputBindings>
                        <Button Content="添加工厂" Margin="0" Click="AddButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Button Content="批量导出" Margin="0" Click="ExportButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Border Style="{StaticResource WarmPanelBorderStyle}" Padding="10">
                <DataGrid Style="{StaticResource GlobalBaseDataGridStyle}"
                          ItemsSource="{Binding Factories}"
                          ColumnHeaderHeight="35"
                          RowHeight="44">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工厂编码" Binding="{Binding FactoryCode}" Width="140" HeaderStyle="{StaticResource GlobalFirstDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="工厂名称" Binding="{Binding FactoryName}" Width="*" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="200" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="类型" Binding="{Binding FactoryType}" Width="180" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTemplateColumn Header="详细信息" Width="80" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Button Click="DetailsButton_Click" Tag="{Binding}" Style="{StaticResource WarmIconButtonStyle}">
                                            <Image Source="/Resources/Icons/icon_expand.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="操作" Width="130" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button ToolTip="编辑" Click="EditButton_Click" Tag="{Binding}" Margin="0,0,5,0"
                                                Style="{StaticResource WarmIconButtonStyle}">
                                            <Image Source="/Resources/Icons/icon_edit.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button ToolTip="删除" Click="DeleteButton_Click" Tag="{Binding}"
                                                Style="{StaticResource WarmIconButtonStyle}">
                                            <Image Source="/Resources/Icons/icon_delete.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
