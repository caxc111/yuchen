<Window x:Class="FactoryProductManager.Views.EditProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FactoryProductManager.Views"
        xmlns:converters="clr-namespace:FactoryProductManager.Converters"
        xmlns:app="clr-namespace:FactoryProductManager"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="编辑产品" Width="620" Height="750"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        app:WindowDragBehavior.Enable="True"
    >
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <Style x:Key="UnifiedDialogLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>
        <Style x:Key="UnifiedDialogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="UnifiedDialogCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Border Style="{StaticResource UnifiedDialogBorderStyle}" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: Title + Window Buttons -->
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <TextBlock Text="编辑产品" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="最小化">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="最大化">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="关闭">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- 第一行：业态 + 项目代码（项目代码只读） -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="业态" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,10,0,0" Width="380">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 业态下拉框 -->
                                    <Grid Grid.Column="0" Width="80">
                                        <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}" Width="80">
                                        </Border>
                                        <ComboBox ItemsSource="{Binding BusinessTypeOptions}"
                                                  SelectedItem="{Binding BusinessType}"
                                                  Style="{StaticResource WarmInputComboBoxStyle}"
                                                  Width="80"/>
                                    </Grid>
                                    <!-- 项目代码标签 -->
                                    <Grid Grid.Column="2">
                                        <Border Width="80" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                            <Grid Width="80" Height="35">
                                                <Border Width="80" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                    <Border.Effect>
                                                        <BlurEffect Radius="20"/>
                                                    </Border.Effect>
                                                </Border>
                                                <TextBlock Text="项目代码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <!-- 项目代码输入框（只读） -->
                                    <Grid Grid.Column="4" Width="200">
                                        <Border Style="{StaticResource WarmFieldBorderStyle}" Background="#E8E8E8" Width="200">
                                        </Border>
                                        <TextBox Text="{Binding Product.ProjectCode, Mode=OneWay}" Style="{StaticResource WarmInputTextBoxStyle}" Width="200" VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0" IsReadOnly="True" Foreground="#666666"/>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <!-- 第二行：部件 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="部件" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,10,0,0" Width="380">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 部件摘要文本框 -->
                                    <Border Grid.Column="0" Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}" VerticalAlignment="Top" Width="260" Padding="0" Height="35"/>
                                    <TextBox Grid.Column="0" x:Name="PartsSummaryTextBox"
                                             Style="{StaticResource WarmInputTextBoxStyle}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             VerticalAlignment="Top"
                                             VerticalContentAlignment="Top"
                                             MinHeight="0"
                                             Height="35"
                                             AcceptsReturn="True"/>
                                    <!-- 编辑部件按钮 -->
                                    <Border Grid.Column="2" Width="110" Height="35" Style="{StaticResource WarmActionBorderStyle}" Background="{StaticResource WarmSurfaceBrush}">
                                        <Grid Width="110" Height="35" ClipToBounds="False">
                                            <Border Width="110" Height="35" CornerRadius="10" ClipToBounds="False" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <Button Content="编辑部件"
                                                    Margin="0"
                                                    Width="110"
                                                    Height="35"
                                                    Click="EditPartsButton_Click"
                                                    Style="{StaticResource UnifiedDialogActionButtonStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- 第三行：户型 + 添加物料 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="户型" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,10,0,0" Width="380">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="260">
                                        <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}" Width="260" Height="35">
                                        </Border>
                                        <TextBox Text="{Binding HouseTypeDisplay, Mode=OneWay}"
                                                 Style="{StaticResource WarmInputTextBoxStyle}"
                                                 IsReadOnly="True"/>
                                    </Grid>
                                    <Border Grid.Column="2" Width="110" Height="35" Style="{StaticResource WarmActionBorderStyle}" Background="{StaticResource WarmSurfaceBrush}">
                                        <Grid Width="110" Height="35" ClipToBounds="False">
                                            <Border Width="110" Height="35" CornerRadius="10" ClipToBounds="False" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <Button Content="添加物料"
                                                    Margin="0"
                                                    Width="110"
                                                    Height="35"
                                                    Click="AddMaterialButton_Click"
                                                    Style="{StaticResource UnifiedDialogActionButtonStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- 第四行：产品编码（只读） -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="产品编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,10,0,0" Width="380">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 产品编码只读 -->
                                    <Grid Grid.Column="0" Width="260">
                                        <Border Style="{StaticResource WarmFieldBorderStyle}" Background="#E8E8E8" Width="260" Height="35">
                                        </Border>
                                        <TextBox Text="{Binding Product.ProductCode, Mode=OneWay}" Style="{StaticResource WarmInputTextBoxStyle}" Height="35" Background="Transparent" BorderThickness="0" IsReadOnly="True" Foreground="#666666"/>
                                    </Grid>
                                    <!-- 删除按钮 -->
                                    <Border Grid.Column="2" Width="110" Height="35" Style="{StaticResource WarmActionBorderStyle}" Background="{StaticResource WarmSurfaceBrush}">
                                        <Grid Width="110" Height="35" ClipToBounds="False">
                                            <Border Width="110" Height="35" CornerRadius="10" ClipToBounds="False" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <Button Content="删除产品"
                                                    Margin="0"
                                                    Width="110"
                                                    Height="35"
                                                    Click="DeleteProductButton_Click"
                                                    Style="{StaticResource UnifiedDialogActionButtonStyle}"
                                                    Foreground="#D32F2F"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- 第五行：面积（只读） -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="面积（㎡）" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,10,0,0" Width="380" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}" Width="380">
                                    </Border>
                                    <TextBox Text="{Binding Product.Area, UpdateSourceTrigger=LostFocus}" Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <!-- 第六行：成本合价（只读） -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="成本合价（元）" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,10,0,0" Width="380" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}" Width="380">
                                    </Border>
                                    <TextBlock Text="{Binding Product.CostTotalPrice, StringFormat='￥{0:N2}'}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Margin="10,0,0,0"
                                               FontSize="14"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>
                            </Grid>

                            <!-- 第七行：均价（只读） -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="均价（元）" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,10,0,0" Width="380" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}" Width="380">
                                    </Border>
                                    <TextBlock Text="{Binding AveragePrice, StringFormat='￥{0:N2}'}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Margin="10,0,0,0"
                                               FontSize="14"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>
                            </Grid>

                            <!-- 第八行：平面图 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="平面图" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Border Grid.Column="1" x:Name="FloorPlanDropZone"
                                        Margin="0,10,0,0" Height="180"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="0"
                                        CornerRadius="10"
                                        Background="#FAFAFA"
                                        AllowDrop="True"
                                        DragOver="FloorPlanDropZone_DragOver"
                                        Drop="FloorPlanDropZone_Drop"
                                        PreviewMouseLeftButtonDown="FloorPlanDropZone_Click">
                                    <Grid>
                                        <Image x:Name="FloorPlanPreviewImage" Stretch="Uniform" Margin="8"/>
                                        <StackPanel x:Name="FloorPlanHintPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button x:Name="FloorPlanPickerButton"
                                                    Width="52"
                                                    Height="52"
                                                    Background="#F4F4F4"
                                                    BorderBrush="#D0D0D0"
                                                    BorderThickness="0"
                                                    FontSize="28"
                                                    Foreground="#666666"
                                                    Cursor="Hand"
                                                    Content="+"
                                                    Click="FloorPlanDropZone_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="26">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock x:Name="FloorPlanHintText"
                                                       Text="点击加号或拖拽图片到这里"
                                                       Foreground="#999999"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- 第九行：是否启用 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="是否启用" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Style="{StaticResource UnifiedDialogLabelTextStyle}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <CheckBox Grid.Column="1" Margin="10,16,0,0" IsChecked="{Binding Product.IsActive}" VerticalAlignment="Center" Style="{StaticResource UnifiedDialogCheckBoxStyle}" Content="启用"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Border Width="90" Height="35" Margin="0,0,15,0" Style="{StaticResource WarmActionBorderStyle}" Background="{StaticResource WarmSurfaceBrush}">
                            <Grid Width="90" Height="35" ClipToBounds="False">
                                <Border Width="90" Height="35" CornerRadius="10" ClipToBounds="False" Background="{StaticResource WarmSurfaceBrush}">
                                    <Border.Effect>
                                        <BlurEffect Radius="20"/>
                                    </Border.Effect>
                                </Border>
                                <Button Content="确定" Margin="0" Width="90" Height="35" Click="OkButton_Click"
                                        Style="{StaticResource UnifiedDialogActionButtonStyle}"/>
                            </Grid>
                        </Border>
                        <Border Width="90" Height="35" Style="{StaticResource WarmActionBorderStyle}" Background="{StaticResource WarmSurfaceBrush}">
                            <Grid Width="90" Height="35" ClipToBounds="False">
                                <Border Width="90" Height="35" CornerRadius="10" ClipToBounds="False" Background="{StaticResource WarmSurfaceBrush}">
                                    <Border.Effect>
                                        <BlurEffect Radius="20"/>
                                    </Border.Effect>
                                </Border>
                                <Button Content="取消" Margin="0" Width="90" Height="35" Click="CancelButton_Click"
                                        Style="{StaticResource UnifiedDialogActionButtonStyle}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
</Window>
