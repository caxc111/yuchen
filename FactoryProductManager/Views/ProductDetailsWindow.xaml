<Window x:Class="FactoryProductManager.Views.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FactoryProductManager"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="产品详细信息" Height="700" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="UnifiedDialogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Style="{StaticResource UnifiedDialogBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏（可拖拽） -->
            <Border Grid.Row="0" Background="{StaticResource WarmHeaderBrush}"
                    CornerRadius="12,12,0,0"
                    local:WindowDragBehavior.Enable="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="产品详细信息"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"/>

                    <!-- 窗口按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="最小化">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="最大化">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="关闭">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容 -->
            <Grid Grid.Row="1" Margin="20">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="产品详细信息" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="业态" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding BusinessType}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="项目代码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding ProjectCode}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="部件" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding PartsSummary}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <!-- 物料详情列表 -->
                                <TextBlock Text="物料详情" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,10,0,8"/>
                                <Border BorderBrush="{StaticResource ActionBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
                                    <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding MaterialsList}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,6" Padding="8,5" Background="#F5F0EB" CornerRadius="4">
                                                        <TextBlock Text="{Binding DisplayText}" 
                                                                   TextWrapping="Wrap" 
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   FontSize="12"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="户型" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding HouseType}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="产品编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding ProductCode}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="面积（㎡）" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Area}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="成本合价（元）" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding CostTotalPrice, StringFormat=F2}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="平面图" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <Image Grid.Column="1" Width="240" Height="160" Stretch="Uniform" HorizontalAlignment="Left">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="{Binding FloorPlan, FallbackValue=/Resources/Icons/icon_no_image.png}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FloorPlan}" Value="{x:Null}">
                                                        <Setter Property="Source" Value="/Resources/Icons/icon_no_image.png"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FloorPlan}" Value="">
                                                        <Setter Property="Source" Value="/Resources/Icons/icon_no_image.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <TextBlock Text="是否启用" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="停用"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Text" Value="启用"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" Width="100" Height="35"
                                HorizontalAlignment="Center" Margin="0,15,0,0"
                                Style="{StaticResource WarmActionBorderStyle}">
                            <Button Content="关闭" Width="100" Height="35"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource UnifiedDialogActionButtonStyle}"
                                    IsCancel="True"/>
                        </Border>
                    </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
