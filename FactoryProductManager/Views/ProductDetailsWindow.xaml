<Window x:Class="FactoryProductManager.Views.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="物料详细信息" Height="560" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Border BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="20">
            <Border.Background>
                <SolidColorBrush Color="#FFF5E6D3" Opacity="0.7"/>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="物料详细信息" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#333333" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center"
                                    CornerRadius="4" BorderBrush="White" BorderThickness="1.2">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <TextBlock Text="工厂物料编码" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="#333333"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding FactoryProductCode}" VerticalAlignment="Center" Foreground="#333333"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center"
                                    CornerRadius="4" BorderBrush="White" BorderThickness="1.2">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <TextBlock Text="宇辰物料编码" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="#333333"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding MyProductCode}" VerticalAlignment="Center" Foreground="#333333"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center"
                                    CornerRadius="4" BorderBrush="White" BorderThickness="1.2">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <TextBlock Text="物料名称" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="#333333"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding ProductName}" VerticalAlignment="Center" Foreground="#333333"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center"
                                    CornerRadius="4" BorderBrush="White" BorderThickness="1.2">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <TextBlock Text="类别" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="#333333"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Category}" VerticalAlignment="Center" Foreground="#333333"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center"
                                    CornerRadius="4" BorderBrush="White" BorderThickness="1.2">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <TextBlock Text="所属工厂" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="#333333"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding FactoryName}" VerticalAlignment="Center" Foreground="#333333"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center"
                                    CornerRadius="4" BorderBrush="White" BorderThickness="1.2">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <TextBlock Text="品牌" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="#333333"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Brand}" VerticalAlignment="Center" Foreground="#333333"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center"
                                    CornerRadius="4" BorderBrush="White" BorderThickness="1.2">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <TextBlock Text="规格" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="#333333"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Specification}" VerticalAlignment="Center" Foreground="#333333"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center"
                                    CornerRadius="4" BorderBrush="White" BorderThickness="1.2">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <TextBlock Text="缩略图" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" Foreground="#333333"/>
                            </Border>
                            <Image Grid.Column="1" Width="160" Height="120" Stretch="Uniform" HorizontalAlignment="Left">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source" Value="{Binding ImageUrl, FallbackValue=/Resources/Icons/icon_no_image.png}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                <Setter Property="Source" Value="/Resources/Icons/icon_no_image.png"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                <Setter Property="Source" Value="/Resources/Icons/icon_no_image.png"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Width="100" Height="35"
                        HorizontalAlignment="Center" Margin="0,15,0,0"
                        Cursor="Hand" CornerRadius="10" BorderBrush="White" BorderThickness="1.2">
                    <Border.Background>
                        <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                    </Border.Background>
                    <Button Content="关闭" Width="100" Height="35"
                            HorizontalAlignment="Center"
                            Background="Transparent" Foreground="#2196F3"
                            BorderBrush="Transparent" BorderThickness="0"
                            FontSize="14" Cursor="Hand"
                            IsCancel="True"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
