<UserControl x:Class="FactoryProductManager.Views.MaterialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <Style x:Key="UnifiedToolbarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Resources/Icons/icon_product.png" Width="32" Height="32" Margin="0,0,10,0"/>
            <TextBlock Text="物料管理" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Border Style="{StaticResource WarmPanelBorderStyle}" Padding="10"/>
            <Border Background="Transparent" BorderThickness="0" CornerRadius="10" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="400" Height="35">
                        <TextBox x:Name="SearchTextBox"
                                 Style="{StaticResource WarmSearchTextBoxStyle}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 Padding="10,0"
                                 FontSize="14"
                                 ToolTip="搜索物料..."/>
                    </Grid>
                    <Border Width="80" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Button Content="搜索" Margin="0" Click="SearchButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Button Content="添加物料" Margin="0" Click="AddButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Button Content="批量导出" Margin="0" Click="ExportButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Border Style="{StaticResource WarmPanelBorderStyle}" Padding="10">
                    <DataGrid Style="{StaticResource GlobalBaseDataGridStyle}"
                          ItemsSource="{Binding Materials}"
                          ColumnHeaderHeight="35"
                          RowHeight="60">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工厂物料编码" Binding="{Binding FactoryMaterialCode}" Width="160" HeaderStyle="{StaticResource GlobalFirstDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>

                        <DataGridTextColumn Header="宇辰物料编码" Binding="{Binding MyMaterialCode}" Width="160" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>

                        <DataGridTextColumn Header="类别" Binding="{Binding CategoryDisplay}" Width="140" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>

                        <DataGridTextColumn Header="所属工厂" Binding="{Binding FactoryName}" Width="*" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>

                        <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="120" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>

                        <DataGridTemplateColumn Header="缩略图" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="44" Height="44" CornerRadius="10" BorderThickness="0" Background="{StaticResource WarmInputBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True" Cursor="Hand" MouseLeftButtonDown="Thumbnail_MouseLeftButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                            <TextBlock Text="无图" FontSize="11" Foreground="{StaticResource HintTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="操作" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button ToolTip="详情" Click="DetailsButton_Click" Tag="{Binding}" Margin="0,0,5,0"
                                                Style="{StaticResource WarmIconButtonStyle}">
                                            <Image Source="/Resources/Icons/icon_expand.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button ToolTip="编辑" Click="EditButton_Click" Tag="{Binding}" Margin="0,0,5,0"
                                                Style="{StaticResource WarmIconButtonStyle}">
                                            <Image Source="/Resources/Icons/icon_edit.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button ToolTip="删除" Click="DeleteButton_Click" Tag="{Binding}"
                                                Style="{StaticResource WarmIconButtonStyle}">
                                            <Image Source="/Resources/Icons/icon_delete.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
