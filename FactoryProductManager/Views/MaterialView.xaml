<UserControl x:Class="FactoryProductManager.Views.MaterialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Margin="10,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Resources/Icons/icon_product.png" Width="32" Height="32" Margin="0,0,10,0"/>
            <TextBlock Text="物料管理" FontSize="24" FontWeight="Bold" Foreground="#000000"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Border BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="#FFF5E6D3" Opacity="0.7"/>
                </Border.Background>
            </Border>
            <Border Background="Transparent" BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="400" Height="35">
                        <Border BorderBrush="White" BorderThickness="1.2" CornerRadius="10">
                            <Border.Background>
                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                            </Border.Background>
                        </Border>
                        <TextBox x:Name="SearchTextBox"
                                 Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                 Foreground="#000000" Padding="10" FontSize="14"
                                 ToolTip="搜索物料..."/>
                    </Grid>
                    <Border Width="80" Height="35" Margin="20,0,0,0" Cursor="Hand" CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                        <Grid Width="80" Height="35" ClipToBounds="False">
                            <Border Width="80" Height="35" CornerRadius="10" ClipToBounds="False">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <Border.Effect>
                                    <BlurEffect Radius="20"/>
                                </Border.Effect>
                            </Border>
                            <Button Content="搜索" Margin="0" Click="SearchButton_Click"
                                    Background="Transparent" Foreground="#2196F3"
                                    BorderBrush="Transparent" BorderThickness="0"
                                    FontSize="14" Cursor="Hand"/>
                        </Grid>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Cursor="Hand" CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                        <Grid Width="100" Height="35" ClipToBounds="False">
                            <Border Width="100" Height="35" CornerRadius="10" ClipToBounds="False">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <Border.Effect>
                                    <BlurEffect Radius="20"/>
                                </Border.Effect>
                            </Border>
                            <Button Content="添加物料" Margin="0" Click="AddButton_Click"
                                    Background="Transparent" Foreground="#4CAF50"
                                    BorderBrush="Transparent" BorderThickness="0"
                                    FontSize="14" Cursor="Hand"/>
                        </Grid>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Cursor="Hand" CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                        <Grid Width="100" Height="35" ClipToBounds="False">
                            <Border Width="100" Height="35" CornerRadius="10" ClipToBounds="False">
                                <Border.Background>
                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                </Border.Background>
                                <Border.Effect>
                                    <BlurEffect Radius="20"/>
                                </Border.Effect>
                            </Border>
                            <Button Content="批量导出" Margin="0" Click="ExportButton_Click"
                                    Background="Transparent" Foreground="#FF9800"
                                    BorderBrush="Transparent" BorderThickness="0"
                                    FontSize="14" Cursor="Hand"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Border BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="#FFF5E6D3" Opacity="0.7"/>
                </Border.Background>
                <DataGrid ItemsSource="{Binding Materials}"
                          AutoGenerateColumns="False"
                          BorderBrush="Transparent"
                          GridLinesVisibility="None"
                          HorizontalGridLinesBrush="Transparent"
                          VerticalGridLinesBrush="Transparent"
                          ColumnHeaderHeight="35"
                          RowHeight="60"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="Transparent"
                          IsReadOnly="True"
                          Margin="0"
                          Padding="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工厂物料编码" Binding="{Binding FactoryMaterialCode}" Width="140">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="Margin" Value="3,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="宇辰物料编码" Binding="{Binding MyMaterialCode}" Width="140">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="类别" Binding="{Binding Category}" Width="180">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="所属工厂" Binding="{Binding FactoryName}" Width="*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="120">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="缩略图" Width="90">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="44" Height="44" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1" Background="#F8F8F8" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                            <TextBlock Text="无图" FontSize="11" Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="操作" Width="130">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False">
                                                    <Grid ClipToBounds="False">
                                                        <Border CornerRadius="10" ClipToBounds="False">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <BlurEffect Radius="20"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button ToolTip="详情" Click="DetailsButton_Click" Tag="{Binding}" Margin="0,0,5,0"
                                                Width="28" Height="28" Background="#F5F5F5"
                                                BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Cursor="Hand">
                                            <Image Source="/Resources/Icons/icon_expand.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button ToolTip="编辑" Click="EditButton_Click" Tag="{Binding}" Margin="0,0,5,0"
                                                Width="28" Height="28" Background="#F5F5F5"
                                                BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Cursor="Hand">
                                            <Image Source="/Resources/Icons/icon_edit.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button ToolTip="删除" Click="DeleteButton_Click" Tag="{Binding}"
                                                Width="28" Height="28" Background="#F5F5F5"
                                                BorderBrush="#E0E0E0" BorderThickness="1" Padding="0" Cursor="Hand">
                                            <Image Source="/Resources/Icons/icon_delete.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#000000"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#000000"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridRow">
                                        <Border CornerRadius="10" BorderBrush="White" BorderThickness="1.2" Background="Transparent" ClipToBounds="False" Margin="2">
                                            <Grid ClipToBounds="False">
                                                <Border CornerRadius="10" ClipToBounds="False">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <BlurEffect Radius="20"/>
                                                    </Border.Effect>
                                                </Border>
                                                <DataGridCellsPresenter/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
