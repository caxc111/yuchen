<Window x:Class="FactoryProductManager.Views.DrawingNumberInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="输入图纸编号" Height="260" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border Style="{StaticResource UnifiedDialogBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource WarmHeaderBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="输入图纸编号"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"/>
                    <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click"
                            HorizontalAlignment="Right" Margin="0,0,5,0" ToolTip="关闭">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>

            <!-- 内容 -->
            <StackPanel Grid.Row="1" Margin="25,25,25,20" VerticalAlignment="Center">
                <TextBlock Text="请输入图纸编号："
                           FontSize="14"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           Margin="0,0,0,12"/>
                <TextBox x:Name="DrawingNumberTextBox"
                         Style="{StaticResource DrawingNumberInputStyle}"
                         FontSize="14"
                         Height="40"
                         VerticalContentAlignment="Center"
                         PreviewKeyDown="DrawingNumberTextBox_PreviewKeyDown"/>
            </StackPanel>

            <!-- 按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,15">
                <Button Content="取消" Click="CancelButton_Click"
                        Width="90" Height="35" Margin="0,0,10,0"
                        Style="{StaticResource AddMaterialButtonStyle}"/>
                <Button Content="确定" Click="OkButton_Click"
                        Width="90" Height="35"
                        Style="{StaticResource AddMaterialButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
