<Window x:Class="FactoryProductManager.Views.PartEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="自定义部件" Height="220" Width="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="UnifiedDialogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Border Style="{StaticResource WarmPanelBorderStyle}" Padding="15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
            </Border.Effect>
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="自定义部件" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,15"/>

                <!-- Form -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="部件名称" FontSize="12" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="PartNameTextBox"
                             Style="{StaticResource WarmInputTextBoxStyle}"
                             Height="32"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="确定" Click="OkButton_Click"
                            Style="{StaticResource UnifiedDialogActionButtonStyle}"
                            Width="80" Height="32" Margin="0,0,10,0"/>
                    <Button Content="取消" Click="CancelButton_Click"
                            Style="{StaticResource UnifiedDialogActionButtonStyle}"
                            Width="80" Height="32"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
