<Window x:Class="FactoryProductManager.Views.FactoryDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FactoryProductManager"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="工厂详细信息" Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize">
    <Border Style="{StaticResource UnifiedDialogBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏（可拖拽） -->
            <Border Grid.Row="0" Background="{StaticResource WarmHeaderBrush}"
                    CornerRadius="12,12,0,0"
                    local:WindowDragBehavior.Enable="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="工厂详细信息"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"/>

                    <!-- 窗口按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="最小化">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="最大化">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="关闭">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容 -->
            <Grid Grid.Row="1" Margin="20">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <TextBlock Grid.Row="0" Text="工厂详细信息" FontSize="18" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,15"/>

                        <!-- 详细信息内容 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="工厂编码" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding FactoryCode}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="工厂名称" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding FactoryName}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="品牌" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding Brand}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="工厂类型" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding FactoryType}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="地址" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding Address}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="联系人" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding ContactPerson}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="联系信息" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding ContactInfo}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="认证情况" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding Certifications}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="工厂规模" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding Scale}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="员工人数" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding EmployeeCount}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="生产能力" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding ProductionCapacity}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="备注" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding Description}" Grid.Column="1" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- 关闭按钮 -->
                        <Button Grid.Row="2" Content="关闭" Width="100" Height="35" 
                                HorizontalAlignment="Center" Margin="0,15,0,0"
                                Click="CloseButton_Click"
                                Background="{StaticResource EditAccentBrush}" Foreground="White" 
                                BorderThickness="0"
                                FontSize="14" Cursor="Hand"/>
                    </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
