<Window x:Class="FactoryProductManager.Views.AddProductMaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FactoryProductManager.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="添加物料" Height="850" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{StaticResource WarmSurfaceBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource ActionBorderBrush}"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Background="{StaticResource WarmHeaderBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="添加物料"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"/>

                <!-- 窗口按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="最小化">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="最大化">
                        <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14"/>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="关闭">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 主内容 -->
            <Border Grid.Row="1" Style="{StaticResource WarmPanelBorderStyle}" Margin="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 上半：左 nav + 右 物料选择（高度自适应内容） -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧导航栏 -->
                        <Grid Grid.Column="0" ClipToBounds="False">
                            <Image Source="Resources/Icons/factory_bg.jpeg" Stretch="Fill"/>
                            <Border Padding="5" Background="Transparent" ClipToBounds="False">
                                <StackPanel ClipToBounds="False">
                                    <TextBlock Text="选择部件" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" Foreground="#333333"
                                               Margin="0,20,0,15"/>
                                    <StackPanel x:Name="NavPanel" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 右侧上半：物料选择（高度自适应，不再独立滚动） -->
                        <Border Grid.Column="1" Margin="20,15,15,5">
                            <StackPanel>
                                <TextBlock x:Name="TitleText" Text="门厅 - 添加物料"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Margin="0,0,0,15"/>
                                <StackPanel x:Name="PartItemsPanel"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 下半：整宽 详细信息大卡（独立滚动） -->
                    <Border Grid.Row="1" Background="{StaticResource WarmHeaderBrush}"
                            CornerRadius="10" Padding="15" Margin="10,5,10,5">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="已选物料详情" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,10"/>

                                <ItemsControl x:Name="SelectedMaterialsPanel">
                                    <ItemsControl.Resources>
                                        <!-- 复合物料大模板（含子项列表、整体删除、合计价） -->
                                        <DataTemplate x:Key="CompositeMaterialTemplate">
                                            <Border Style="{StaticResource SelectedMaterialItemStyle}" Padding="12" Margin="0,0,0,10"
                                                    BorderBrush="#E67E22" BorderThickness="1.2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- 标题行：组合名 + 数量 + 总价 -->
                                                    <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="🧩" FontSize="14"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding MaterialName}"
                                                                   FontSize="15" FontWeight="Bold"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" FontSize="15" FontWeight="Bold"
                                                                   Foreground="#E67E22" VerticalAlignment="Center">
                                                            <Run Text="合计 ¥"/><Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                                        </TextBlock>
                                                    </Grid>

                                                    <!-- 部件/部品 -->
                                                    <TextBlock Grid.Row="1" Grid.Column="0" FontSize="11"
                                                               Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,6">
                                                        <Run Text="部件："/><Run Text="{Binding PartName}"/>
                                                        <Run Text="  部品："/><Run Text="{Binding ComponentName}"/>
                                                    </TextBlock>

                                                    <!-- 子项列表 -->
                                                    <ItemsControl Grid.Row="2" Grid.Column="0" ItemsSource="{Binding Children}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="{StaticResource InputBorderBrush}"
                                                                        BorderThickness="0,1,0,0" Padding="0,6,0,6" Margin="0,0,0,0">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="80"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="60"/>
                                                                            <ColumnDefinition Width="90"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="{Binding ItemName}"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource SubtleTextBrush}"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding MaterialName}"
                                                                                   FontSize="12" Foreground="{StaticResource PrimaryTextBrush}"
                                                                                   TextWrapping="Wrap"/>
                                                                        <TextBlock Grid.Column="2" FontSize="12"
                                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                                   TextAlignment="Right">
                                                                            <Run Text="¥"/><Run Text="{Binding UnitPrice, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                                                        </TextBlock>
                                                                        <TextBlock Grid.Column="3" FontSize="12" FontWeight="Bold"
                                                                                   Foreground="#E67E22" TextAlignment="Right">
                                                                            <Run Text="小计 ¥"/><Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- 删除（整体删除复合物料） -->
                                                    <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                                                            Content="×" Click="DeleteMaterial_Click"
                                                            Style="{StaticResource DeleteButtonStyle}"
                                                            Tag="{Binding}"
                                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                                            Margin="0,2,2,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    
                                        <!-- 普通物料大模板（缩略图 + 9 字段 + 删除） -->
                                        <DataTemplate x:Key="SingleMaterialTemplate">
                                            <Border Style="{StaticResource SelectedMaterialItemStyle}" Padding="12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                                            Width="120" Height="120" CornerRadius="6"
                                                            Background="{StaticResource WarmPanelBrush}" Cursor="Hand"
                                                            BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="0.8"
                                                            MouseLeftButtonUp="Thumbnail_Click"
                                                            HorizontalAlignment="Center" VerticalAlignment="Top"
                                                            ClipToBounds="True"
                                                            Margin="0,0,12,0"
                                                            Tag="{Binding}">
                                                        <Grid>
                                                            <TextBlock Text="无图片" FontSize="11" HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" Foreground="{StaticResource HintTextBrush}"
                                                                       Visibility="{Binding ImageUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"
                                                                   Visibility="{Binding ImageUrl, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding MaterialName}"
                                                               FontSize="15" FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Top"
                                                               Margin="0,0,0,8"/>
                                                    <Grid Grid.Row="1" Grid.Column="1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="部件："
                                                                   FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                                                                   Margin="0,3"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   Text="{Binding PartName}"
                                                                   FontSize="12" Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextWrapping="Wrap" Margin="0,3"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="部品："
                                                                   FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                                                                   Margin="10,3,0,3"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ComponentName}"
                                                                   FontSize="12" Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextWrapping="Wrap" Margin="0,3"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="规格："
                                                                   FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                                                                   Margin="0,3"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Specification}"
                                                                   FontSize="12" Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextWrapping="Wrap" Margin="0,3"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="单位："
                                                                   FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                                                                   Margin="10,3,0,3"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Unit}"
                                                                   FontSize="12" Foreground="{StaticResource PrimaryTextBrush}"
                                                                   TextWrapping="Wrap" Margin="0,3"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="数量："
                                                                   FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                                                                   Margin="0,3"/>
                                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                                 Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource QuantityTextBoxStyle}"
                                                                 Width="60" HorizontalAlignment="Left" Margin="0,1"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="单价："
                                                                   FontSize="12" Foreground="{StaticResource SubtleTextBrush}"
                                                                   Margin="10,3,0,3"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="3" FontSize="12"
                                                                   Foreground="{StaticResource PrimaryTextBrush}" Margin="0,3">
                                                            <Run Text="¥"/><Run Text="{Binding UnitPrice, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                                        </TextBlock>
                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="总价："
                                                                   FontSize="13" FontWeight="Bold"
                                                                   Foreground="#E67E22" Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                                                                   FontSize="15" FontWeight="Bold" Foreground="#E67E22"
                                                                   Margin="0,4,0,0">
                                                            <Run Text="¥"/><Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                                        </TextBlock>
                                                    </Grid>
                                                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                            Content="×" Click="DeleteMaterial_Click"
                                                            Style="{StaticResource DeleteButtonStyle}"
                                                            Tag="{Binding}"
                                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                                            Margin="0,2,2,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.Resources>
                                    <ItemsControl.ItemTemplateSelector>
                                        <local:SelectedMaterialTemplateSelector
                                            CompositeTemplate="{StaticResource CompositeMaterialTemplate}"
                                            SingleTemplate="{StaticResource SingleMaterialTemplate}"/>
                                    </ItemsControl.ItemTemplateSelector>

                                </ItemsControl>

                                <TextBlock x:Name="EmptyMaterialsText"
                                           Text="暂无已选物料" FontSize="13"
                                           Foreground="{StaticResource HintTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,30,0,0"
                                           Visibility="Visible"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,12">
                <Button Content="取消" Click="CancelButton_Click"
                        Width="90" Height="35" Margin="0,0,10,0"
                        Style="{StaticResource AddMaterialButtonStyle}"/>
                <Button Content="确定添加" Click="OkButton_Click"
                        Width="100" Height="35"
                        Style="{StaticResource AddMaterialButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
