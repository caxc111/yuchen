<Window x:Class="FactoryProductManager.Views.AddProductMaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FactoryProductManager.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="添加物料" Height="650" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{StaticResource WarmSurfaceBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource ActionBorderBrush}"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Background="{StaticResource WarmHeaderBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="添加物料"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"/>

                <!-- 窗口按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="最小化">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="最大化">
                        <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14"/>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="关闭">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 主内容 -->
            <Border Grid.Row="1" Style="{StaticResource WarmPanelBorderStyle}" Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧导航栏 -->
                    <Grid Grid.Column="0" ClipToBounds="False">
                        <Image Source="Resources/Icons/factory_bg.jpeg" Stretch="Fill"/>
                        <Border Padding="5" Background="Transparent" ClipToBounds="False">
                            <StackPanel ClipToBounds="False">
                                <TextBlock Text="选择部位" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="#333333"
                                           Margin="0,20,0,15"/>
                                <StackPanel x:Name="NavPanel" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 右侧主内容 -->
                    <Grid Grid.Column="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TitleText" Grid.Row="0" Text="门厅 - 添加物料"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PartItemsPanel"/>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="{StaticResource WarmHeaderBrush}"
                                CornerRadius="10" Padding="15" Margin="0,15,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="120"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="已选物料" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,10"/>

                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="物料名称" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="规格" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="2" Text="单价" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="3" Text="数量" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="4" Text="" FontWeight="Bold" FontSize="12"/>
                                </Grid>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="SelectedMaterialsPanel">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource SelectedMaterialItemStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding MaterialName}"
                                                                   VerticalAlignment="Center" FontSize="13"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Specification}"
                                                                   VerticalAlignment="Center" FontSize="13"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13"
                                                                   Foreground="{StaticResource PrimaryTextBrush}">
                                                            <Run Text="¥"/><Run Text="{Binding UnitPrice, StringFormat={}{0:F2}}"/>
                                                        </TextBlock>
                                                        <TextBox Grid.Column="3" Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource QuantityTextBoxStyle}"/>
                                                        <Button Grid.Column="4" Content="×" Click="DeleteMaterial_Click"
                                                                Style="{StaticResource DeleteButtonStyle}"
                                                                Tag="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock x:Name="EmptyMaterialsText" Grid.Row="2"
                                           Text="暂无已选物料" FontSize="13"
                                           Foreground="{StaticResource HintTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Visible"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button Content="取消" Click="CancelButton_Click"
                                    Width="90" Height="35" Margin="0,0,10,0"
                                    Style="{StaticResource AddMaterialButtonStyle}"/>
                            <Button Content="确定添加" Click="OkButton_Click"
                                    Width="100" Height="35"
                                    Style="{StaticResource AddMaterialButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
