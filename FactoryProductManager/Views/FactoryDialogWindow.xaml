<Window x:Class="FactoryProductManager.Views.FactoryDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FactoryProductManager.Views"
        mc:Ignorable="d"
        Title="工厂信息" Height="550" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <!-- 内容层 -->
        <ContentControl x:Name="DialogContent"/>
    </Grid>
</Window>
