<Window x:Class="FactoryProductManager.Views.MaterialDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="物料详细信息" Height="560" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="物料详细信息" FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Foreground="#333333" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="工厂物料编码" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/><TextBlock Text="{Binding FactoryMaterialCode}" Grid.Column="1" Foreground="#333333"/></Grid>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="宇辰物料编码" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/><TextBlock Text="{Binding MyMaterialCode}" Grid.Column="1" Foreground="#333333"/></Grid>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="物料名称" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/><TextBlock Text="{Binding MaterialName}" Grid.Column="1" Foreground="#333333"/></Grid>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="类别" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/><TextBlock Text="{Binding Category}" Grid.Column="1" Foreground="#333333"/></Grid>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="所属工厂" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/><TextBlock Text="{Binding FactoryName}" Grid.Column="1" Foreground="#333333"/></Grid>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="品牌" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/><TextBlock Text="{Binding Brand}" Grid.Column="1" Foreground="#333333"/></Grid>
                <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="规格" Grid.Column="0" FontWeight="Bold" Foreground="#666666"/><TextBlock Text="{Binding Specification}" Grid.Column="1" Foreground="#333333"/></Grid>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="关闭" Width="100" Height="35"
                HorizontalAlignment="Center" Margin="0,15,0,0"
                Click="CloseButton_Click"
                Background="#2196F3" Foreground="White"
                BorderBrush="#1976D2" BorderThickness="0"
                FontSize="14" Cursor="Hand"/>
    </Grid>
</Window>
