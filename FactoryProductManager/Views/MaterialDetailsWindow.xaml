<Window x:Class="FactoryProductManager.Views.MaterialDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="物料详细信息" Height="560" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="UnifiedDialogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Border Style="{StaticResource WarmPanelBorderStyle}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="物料详细信息" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                <TextBlock Text="工厂物料编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding FactoryMaterialCode}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                <TextBlock Text="宇辰物料编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding MyMaterialCode}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                <TextBlock Text="物料名称" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding MaterialName}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                <TextBlock Text="类别" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding CategoryDisplay}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                <TextBlock Text="所属工厂" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding FactoryName}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                <TextBlock Text="品牌" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Brand}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                <TextBlock Text="规格" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Specification}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Width="100" Height="35"
                        HorizontalAlignment="Center" Margin="0,15,0,0"
                        Style="{StaticResource WarmActionBorderStyle}">
                    <Button Grid.Row="2" Content="关闭" Width="100" Height="35"
                            HorizontalAlignment="Center"
                            Margin="0"
                            Click="CloseButton_Click"
                            Style="{StaticResource UnifiedDialogActionButtonStyle}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
