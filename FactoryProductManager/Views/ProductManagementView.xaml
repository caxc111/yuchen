<UserControl x:Class="FactoryProductManager.Views.ProductManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="UnifiedToolbarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Resources/Icons/icon_product_management.png" Width="32" Height="32" Margin="0,0,10,0"/>
            <TextBlock Text="产品管理" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Border Style="{StaticResource WarmPanelBorderStyle}" Padding="10"/>
            <Border Background="Transparent" BorderThickness="0" CornerRadius="10" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="400" Height="35">
                        <TextBox x:Name="SearchTextBox"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource WarmSearchTextBoxStyle}"
                                 Foreground="{StaticResource PrimaryTextBrush}" Padding="10,0" FontSize="14"
                                 ToolTip="搜索产品..."/>
                    </Grid>
                    <Border Width="80" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Button Content="搜索" Margin="0" Click="SearchButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Button Content="添加产品" Margin="0" Click="AddButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                    <Border Width="100" Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}">
                        <Button Content="批量导出" Margin="0" Click="ExportButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                    <Border Height="35" Margin="20,0,0,0" Style="{StaticResource WarmActionBorderStyle}"
                        Visibility="{Binding HasInactiveProductsVisibility}">
                        <Button Content="{Binding ShowInactiveButtonText}" Margin="0" Click="ToggleInactiveButton_Click"
                                Style="{StaticResource UnifiedToolbarActionButtonStyle}"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource WarmPanelBorderStyle}" Padding="10">
                <DataGrid Style="{StaticResource GlobalBaseDataGridStyle}"
                          ItemsSource="{Binding DisplayProducts}"
                          ColumnHeaderHeight="35"
                          RowHeight="60"
                          VerticalContentAlignment="Center">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="业态" Binding="{Binding BusinessType}" Width="80" HeaderStyle="{StaticResource GlobalFirstDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="产品编码" Binding="{Binding ProductCode}" Width="180" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="项目代码" Binding="{Binding ProjectCode}" Width="120" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="户型" Binding="{Binding HouseType}" Width="*" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="面积（㎡）" Binding="{Binding Area}" Width="90" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="成本合价（元）" Binding="{Binding CostTotalPrice, StringFormat=F2}" Width="140" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTextColumn Header="成本均价" Binding="{Binding CostAveragePrice, StringFormat=F2}" Width="100" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}" ElementStyle="{StaticResource GlobalDataGridTextElementStyle}"/>
                        <DataGridTemplateColumn Header="平面图" Width="80" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="44" Height="44" CornerRadius="8" BorderThickness="0" Background="{StaticResource WarmInputBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True" Cursor="Hand" MouseLeftButtonDown="FloorPlanImage_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Image Source="{Binding FloorPlan}" Stretch="UniformToFill"/>
                                            <TextBlock Text="无图" FontSize="11" Foreground="{StaticResource HintTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FloorPlan}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FloorPlan}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="状态" Width="80" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="StatusBorder" Background="Transparent" CornerRadius="4" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" MouseLeftButtonDown="StatusToggle_Click" Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="启用"/>
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text" Value="停用"/>
                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="操作" Width="130" HeaderStyle="{StaticResource GlobalDataGridHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button ToolTip="详情" Tag="{Binding}" Margin="0,0,5,0"
                                                Style="{StaticResource WarmIconButtonStyle}" Click="DetailsButton_Click">
                                            <Image Source="/Resources/Icons/icon_expand.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button ToolTip="编辑" Tag="{Binding}" Margin="0,0,5,0"
                                                Style="{StaticResource WarmIconButtonStyle}" Click="EditButton_Click">
                                            <Image Source="/Resources/Icons/icon_edit.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button ToolTip="删除" Tag="{Binding}"
                                                Style="{StaticResource WarmIconButtonStyle}" Click="DeleteButton_Click">
                                            <Image Source="/Resources/Icons/icon_delete.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                    <Setter Property="Background" Value="#FFF5E6"/>
                                    <Setter Property="Foreground" Value="#999999"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
