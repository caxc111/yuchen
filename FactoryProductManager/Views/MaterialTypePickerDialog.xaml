<Window x:Class="FactoryProductManager.Views.MaterialTypePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择物料类型" Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border Background="{StaticResource WarmSurfaceBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource ActionBorderBrush}"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20">
                <TextBlock x:Name="TitleText" Text="请选择物料类型"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           Margin="0,0,0,15"/>
                <ItemsControl x:Name="TypeList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" CornerRadius="8"
                                    Background="{StaticResource WarmHeaderBrush}"
                                    BorderBrush="{StaticResource ActionBorderBrush}"
                                    BorderThickness="0.8"
                                    Padding="12,10"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="Item_Click"
                                    Tag="{Binding}">
                                <TextBlock Text="{Binding}" FontSize="13"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,15">
                <Button Content="取消" Click="CancelButton_Click"
                        Width="80" Height="32" Margin="0,0,10,0"
                        Style="{StaticResource AddMaterialButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
