<UserControl x:Class="FactoryProductManager.Views.MaterialDialogUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="UnifiedDialogLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>
        <Style x:Key="UnifiedDialogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource WarmActionButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmButtonBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarmActionBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource WarmPanelBorderStyle}" Padding="15">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="类别" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Height="35">
                                        <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                        </Border>
                                        <ComboBox x:Name="CategoryLevel1"
                                                  SelectionChanged="CategoryLevel1_SelectionChanged"
                                                  Style="{StaticResource WarmInputComboBoxStyle}"/>
                                    </Grid>
                                    <Grid Grid.Column="2" Height="35">
                                        <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                        </Border>
                                        <ComboBox x:Name="CategoryLevel2"
                                                  SelectionChanged="CategoryLevel2_SelectionChanged"
                                                  Style="{StaticResource WarmInputComboBoxStyle}"/>
                                    </Grid>
                                    <Grid x:Name="Level3Border" Grid.Column="4" Height="35">
                                        <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                        </Border>
                                        <ComboBox x:Name="CategoryLevel3"
                                                  SelectionChanged="CategoryLevel3_SelectionChanged"
                                                  Style="{StaticResource WarmInputComboBoxStyle}"/>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="工厂名称" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Grid.Resources>
                                        <DataTemplate x:Key="FactoryOptionItemTemplate">
                                            <TextBlock Text="{Binding DisplayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelectable}" Value="False">
                                                                <Setter Property="Foreground" Value="#F2B366"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </Grid.Resources>
                                    <Border x:Name="FactoryNameBorder" BorderThickness="0" BorderBrush="#CCCCCC" CornerRadius="10" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <ComboBox x:Name="FactoryNameComboBox"
                                              SelectionChanged="FactoryNameComboBox_SelectionChanged"
                                              Style="{StaticResource WarmInputComboBoxStyle}"
                                              ItemTemplate="{StaticResource FactoryOptionItemTemplate}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="物料名称" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox x:Name="MaterialNameTextBox" Text="{Binding Material.MaterialName}"
                                             IsReadOnly="True" Cursor="Arrow"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="工厂物料编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox Text="{Binding Material.FactoryMaterialCode}"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="宇辰物料编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                        </Border>
                                        <TextBox x:Name="MyMaterialCodeTextBox" Text="{Binding Material.MyMaterialCode}"
                                                 Style="{StaticResource WarmInputTextBoxStyle}"/>
                                    </Grid>
                                    <Button Grid.Column="1" Margin="10,0,0,0" Content="编码生成"
                                            Click="GenerateMyMaterialCodeButton_Click"
                                            Style="{StaticResource UnifiedDialogActionButtonStyle}"
                                            FontSize="12" Foreground="{StaticResource PrimaryTextBrush}"/>

                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="品牌" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <ComboBox x:Name="BrandComboBox"
                                              SelectionChanged="BrandComboBox_SelectionChanged"
                                              Style="{StaticResource WarmInputComboBoxStyle}"
                                              HorizontalContentAlignment="Stretch"
                                              VerticalContentAlignment="Center"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="规格" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox Text="{Binding Material.Specification}"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="纹理" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox Text="{Binding Material.Texture}"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="工艺" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox Text="{Binding Material.Process}"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="单位" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <ComboBox x:Name="UnitComboBox"
                                              ItemsSource="{Binding UnitOptions}"
                                              SelectedItem="{Binding Material.Unit}"
                                              SelectionChanged="UnitComboBox_SelectionChanged"
                                              Style="{StaticResource WarmInputComboBoxStyle}"
                                              HorizontalContentAlignment="Stretch"
                                              VerticalContentAlignment="Center"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="成本价格" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox x:Name="CostPriceTextBox"
                                             LostFocus="CostPriceTextBox_LostFocus"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="适用场景" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox Text="{Binding Material.UsageScenario}"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="认证情况" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border Style="{StaticResource WarmFieldBorderStyle}" Background="{StaticResource WarmInputBrush}">
                                    </Border>
                                    <TextBox Text="{Binding Material.Certifications}"
                                             Style="{StaticResource WarmInputTextBoxStyle}"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" Style="{StaticResource WarmTagBorderStyle}">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="10" Background="{StaticResource WarmSurfaceBrush}">
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="图片" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <StackPanel Grid.Column="1" Margin="10,10,0,0" Width="420">
                                    <Border x:Name="ImageDropZone"
                                            Height="180"
                                            BorderBrush="#CCCCCC"
                                            BorderThickness="0"
                                            CornerRadius="10"
                                            Background="#FAFAFA"
                                            AllowDrop="True"
                                            DragOver="ImageDropZone_DragOver"
                                            Drop="ImageDropZone_Drop">
                                        <Grid>
                                            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="8"/>
                                            <Button x:Name="ImagePickerButton"
                                                    Click="ImageDropZone_Click"
                                                    Width="52"
                                                    Height="52"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="#F4F4F4"
                                                    BorderBrush="#D0D0D0"
                                                    BorderThickness="0"
                                                    FontSize="28"
                                                    Foreground="#666666"
                                                    Cursor="Hand"
                                                    Content="+">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="26">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock x:Name="ImageHintText"
                                                       Text="点击加号或拖拽图片到这里"
                                                       Foreground="{StaticResource HintTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,72,0,0"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="取消" Width="90" Height="34" Margin="0,0,10,0" Click="CancelButton_Click"
                                Style="{StaticResource UnifiedDialogActionButtonStyle}"/>
                        <Button Content="确定" Width="90" Height="34" Click="OkButton_Click"
                                Style="{StaticResource UnifiedDialogActionButtonStyle}"
                                Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
