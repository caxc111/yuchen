<UserControl x:Class="FactoryProductManager.Views.MaterialDialogUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid>
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.RowSpan="3" BorderBrush="White" BorderThickness="1.2" CornerRadius="10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="15" Opacity="0.25" Color="Black"/>
                </Border.Effect>
                <Border.Background>
                    <SolidColorBrush Color="#FFF5E6D3" Opacity="0.7"/>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#333333"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="类别" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Height="35">
                                        <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                            <Border.Background>
                                                <SolidColorBrush Color="White" Opacity="0.9"/>
                                            </Border.Background>
                                        </Border>
                                        <ComboBox x:Name="CategoryLevel1"
                                                  SelectionChanged="CategoryLevel1_SelectionChanged"
                                                  Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                                  Padding="8,0,30,0" FontSize="13" Foreground="#333333"/>
                                        <Path Width="10" Height="6" Fill="#666666" Stretch="Fill" Margin="0,0,12,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Data="M0,0 L10,0 L5,6 Z"/>
                                    </Grid>
                                    <Grid Grid.Column="2" Height="35">
                                        <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                            <Border.Background>
                                                <SolidColorBrush Color="White" Opacity="0.9"/>
                                            </Border.Background>
                                        </Border>
                                        <ComboBox x:Name="CategoryLevel2"
                                                  SelectionChanged="CategoryLevel2_SelectionChanged"
                                                  Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                                  Padding="8,0,30,0" FontSize="13" Foreground="#333333"/>
                                        <Path Width="10" Height="6" Fill="#666666" Stretch="Fill" Margin="0,0,12,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Data="M0,0 L10,0 L5,6 Z"/>
                                    </Grid>
                                    <Grid x:Name="Level3Border" Grid.Column="4" Height="35">
                                        <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                            <Border.Background>
                                                <SolidColorBrush Color="White" Opacity="0.9"/>
                                            </Border.Background>
                                        </Border>
                                        <ComboBox x:Name="CategoryLevel3"
                                                  SelectionChanged="CategoryLevel3_SelectionChanged"
                                                  Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                                  Padding="8,0,30,0" FontSize="13" Foreground="#333333"/>
                                        <Path Width="10" Height="6" Fill="#666666" Stretch="Fill" Margin="0,0,12,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Data="M0,0 L10,0 L5,6 Z"/>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="工厂名称" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Grid.Resources>
                                        <DataTemplate x:Key="FactoryOptionItemTemplate">
                                            <TextBlock Text="{Binding DisplayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#333333"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelectable}" Value="False">
                                                                <Setter Property="Foreground" Value="#F2B366"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </Grid.Resources>
                                    <Border x:Name="FactoryNameBorder" BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <ComboBox x:Name="FactoryNameComboBox"
                                              SelectionChanged="FactoryNameComboBox_SelectionChanged"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Padding="8,0,30,0"
                                              FontSize="13"
                                              Foreground="#333333"
                                              ItemTemplate="{StaticResource FactoryOptionItemTemplate}"/>
                                    <Path Width="10" Height="6" Fill="#666666" Stretch="Fill" Margin="0,0,12,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Data="M0,0 L10,0 L5,6 Z"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="物料名称" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox x:Name="MaterialNameTextBox" Text="{Binding Material.MaterialName}"
                                             IsReadOnly="True" Cursor="Arrow"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="工厂物料编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Material.FactoryMaterialCode}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="宇辰物料编码" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                            <Border.Background>
                                                <SolidColorBrush Color="White" Opacity="0.9"/>
                                            </Border.Background>
                                        </Border>
                                        <TextBox x:Name="MyMaterialCodeTextBox" Text="{Binding Material.MyMaterialCode}"
                                                 Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                                 Padding="8" FontSize="13" Foreground="#333333"/>
                                    </Grid>
                                    <Button Grid.Column="1" Margin="10,0,0,0" Content="编码生成"
                                            Click="GenerateMyMaterialCodeButton_Click"
                                            FontSize="12" Foreground="White" Background="#4A90E2"
                                            BorderBrush="#4A90E2" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="品牌" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <ComboBox x:Name="BrandComboBox"
                                              SelectionChanged="BrandComboBox_SelectionChanged"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Padding="4,2"
                                              FontSize="13"
                                              Foreground="#333333"
                                              HorizontalContentAlignment="Stretch"
                                              VerticalContentAlignment="Center"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="规格" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Material.Specification}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="纹理" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Material.Texture}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="工艺" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Material.Process}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="适用场景" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Material.UsageScenario}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="认证情况" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Grid Grid.Column="1" Margin="10,10,0,0" Width="420" Height="35">
                                    <Border BorderThickness="1.2" BorderBrush="#CCCCCC" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="White" Opacity="0.9"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBox Text="{Binding Material.Certifications}"
                                             Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                             Padding="8" FontSize="13" Foreground="#333333"/>
                                </Grid>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,10,0,0">
                                    <Border Width="110" Height="35" HorizontalAlignment="Center" CornerRadius="4" BorderBrush="White" BorderThickness="1.2" Background="Transparent">
                                        <Grid Width="110" Height="35">
                                            <Border Width="110" Height="35" CornerRadius="4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="LightGray" Opacity="0.9"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="20"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="图片" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#333333"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <StackPanel Grid.Column="1" Margin="10,10,0,0" Width="420">
                                    <Border x:Name="ImageDropZone"
                                            Height="180"
                                            BorderBrush="#CCCCCC"
                                            BorderThickness="1.2"
                                            CornerRadius="4"
                                            Background="#FAFAFA"
                                            AllowDrop="True"
                                            DragOver="ImageDropZone_DragOver"
                                            Drop="ImageDropZone_Drop">
                                        <Grid>
                                            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="8"/>
                                            <Button x:Name="ImagePickerButton"
                                                    Click="ImageDropZone_Click"
                                                    Width="52"
                                                    Height="52"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="#F4F4F4"
                                                    BorderBrush="#D0D0D0"
                                                    BorderThickness="1.2"
                                                    FontSize="28"
                                                    Foreground="#666666"
                                                    Cursor="Hand"
                                                    Content="+">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="26">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock x:Name="ImageHintText"
                                                       Text="点击加号或拖拽图片到这里"
                                                       Foreground="#888888"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,72,0,0"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="取消" Width="90" Height="34" Margin="0,0,10,0" Click="CancelButton_Click"/>
                        <Button Content="确定" Width="90" Height="34" Click="OkButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
