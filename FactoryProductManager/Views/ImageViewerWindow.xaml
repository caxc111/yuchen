<Window x:Class="FactoryProductManager.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="查看图片"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">
    <Border Background="#E8E8E8"
            CornerRadius="8"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="8,8,0,0" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitleText" Grid.Column="0" Text="查看图片"
                               FontSize="13" FontWeight="Bold"
                               Foreground="#333333"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"/>

                    <!-- 窗口按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="最小化">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="12" Height="12"/>
                        </Button>
                        <Button Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="最大化">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="12" Height="12"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButtonStyle}" Click="CloseButton_Click" ToolTip="关闭">
                            <materialDesign:PackIcon Kind="Close" Width="12" Height="12"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 图片显示区域 -->
            <Border Grid.Row="1" Background="Transparent" ClipToBounds="True">
                <Grid>
                    <ScrollViewer x:Name="ImageScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#F5F5F5">
                        <Image x:Name="DisplayImage"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               MouseLeftButtonDown="DisplayImage_MouseLeftButtonDown"/>
                    </ScrollViewer>

                    <!-- 图片信息标签 -->
                    <Border x:Name="InfoPanel"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Margin="15"
                            Padding="12,8"
                            Background="#CC000000"
                            CornerRadius="6"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="MaterialNameText" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock x:Name="MaterialCodeText" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,2"/>
                            <TextBlock x:Name="SpecificationText" FontSize="12" Foreground="#CCCCCC"/>
                        </StackPanel>
                    </Border>

                    <!-- 原图按钮 -->
                    <Button x:Name="OriginalSizeButton"
                            Content="显示原图"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="15"
                            Padding="12,6"
                            Background="White"
                            BorderBrush="#CCCCCC"
                            Click="OriginalSizeButton_Click"
                            Visibility="Collapsed"
                            FontSize="12">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
