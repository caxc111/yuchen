<Window x:Class="FactoryProductManager.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:FactoryProductManager"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding WindowTitle}"
        Width="900" Height="700"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Border Style="{StaticResource UnifiedDialogBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏（可拖拽） -->
            <Border x:Name="WindowBorder" Grid.Row="0" Background="{StaticResource WarmHeaderBrush}"
                    CornerRadius="12,12,0,0" Padding="15,10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource WindowButtonStyle}"
                                Click="MinimizeButton_Click"
                                ToolTip="最小化">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="MaximizeButton"
                                Style="{StaticResource WindowButtonStyle}"
                                Click="MaximizeButton_Click"
                                ToolTip="最大化">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButtonStyle}"
                                Click="CloseButton_Click"
                                ToolTip="关闭">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 图片内容区 -->
            <Border Grid.Row="1" Background="{StaticResource WarmHeaderBrush}" ClipToBounds="True">
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <Image x:Name="ViewerImage"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Viewbox>
            </Border>
        </Grid>
    </Border>
</Window>
