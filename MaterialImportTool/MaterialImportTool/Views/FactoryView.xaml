<UserControl x:Class="MaterialImportTool.Views.FactoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid Background="#FFF5E6D3">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="White" Margin="0,0,0,10">
            <Button DockPanel.Dock="Left" Background="Transparent" BorderThickness="0" Padding="10"
                    Click="BackButton_Click">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" Foreground="#333333"/>
            </Button>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <materialDesign:PackIcon Kind="Building" Width="28" Height="28" Foreground="#4CAF50"/>
                <TextBlock Text="添加工厂" FontSize="24" Margin="10,0,0,0" Foreground="#333333"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,20,0">
                <Button Background="Transparent" BorderThickness="0" Padding="10"
                        Command="{Binding ExportCommand}">
                    <materialDesign:PackIcon Kind="Download" Width="24" Height="24" Foreground="#333333"/>
                </Button>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox Width="250" Height="36" 
                         Text="{Binding SearchText}"
                         materialDesign:HintAssist.Hint="搜索工厂名称或编码"/>
                <Button Content="搜索" Width="80" Margin="10,0,0,0"
                        Background="#666666" Foreground="White" BorderThickness="0" Padding="10,5"/>
                <Button Content="新增工厂" Margin="10,0,0,0"
                        Command="{Binding AddFactoryCommand}"
                        Background="#4CAF50" Foreground="White" BorderThickness="0" Padding="10,5"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Factories}"
                      SelectedItem="{Binding SelectedFactory}"
                      AutoGenerateColumns="False"
                      Background="White" RowBackground="White" AlternatingRowBackground="#F9F9F9"
                      BorderThickness="1" BorderBrush="#DDDDDD"
                      ColumnHeaderHeight="35" RowHeight="30">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F5F5F5"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,5"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="工厂编码" Binding="{Binding FactoryCode}" Width="120"/>
                    <DataGridTextColumn Header="工厂名称" Binding="{Binding FactoryName}" Width="150"/>
                    <DataGridTextColumn Header="工厂类型" Binding="{Binding FactoryType}" Width="120"/>
                    <DataGridTextColumn Header="联系人" Binding="{Binding ContactPerson}" Width="100"/>
                    <DataGridTextColumn Header="联系信息" Binding="{Binding ContactInfo}" Width="150"/>
                    <DataGridTemplateColumn Header="操作" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.EditFactoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            Background="Transparent" BorderThickness="0" Padding="5">
                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="#333333"/>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteFactoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            Background="Transparent" BorderThickness="0" Padding="5">
                                        <materialDesign:PackIcon Kind="Trash" Width="18" Height="18" Foreground="#F44336"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <materialDesign:DialogHost Identifier="FactoryDialog" IsOpen="{Binding IsDialogOpen}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Building" Width="24" Height="24"/>
                    <TextBlock Text="{Binding EditingFactory.Id, Converter={StaticResource IdToTitleConverter}}" 
                               FontSize="18" Margin="10,0,0,0"/>
                </StackPanel>

                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="工厂编码：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditingFactory.FactoryCode}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="工厂名称：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding EditingFactory.FactoryName}"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="品牌：" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="1" Grid.Column="3">
                        <TextBox Text="{Binding EditingFactory.Brand}"/>
                        <TextBlock Text="多个品牌请用 / 分隔"
                                   Margin="4,4,0,0"
                                   FontSize="11"
                                   Foreground="#999999"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="工厂类型：" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" SelectedValuePath="Content">
                        <ComboBoxItem Content="柜体木饰面"/>
                        <ComboBoxItem Content="木地板"/>
                        <ComboBoxItem Content="地毯"/>
                        <ComboBoxItem Content="瓷砖"/>
                        <ComboBoxItem Content="石材"/>
                        <ComboBoxItem Content="厨卫陶瓷"/>
                        <ComboBoxItem Content="厨卫五金"/>
                        <ComboBoxItem Content="户内门"/>
                        <ComboBoxItem Content="灯具开关"/>
                        <ComboBoxItem Content="电器"/>
                    </ComboBox>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="地址：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding EditingFactory.Address}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="认证情况：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditingFactory.Certifications}"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="联系人：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding EditingFactory.ContactPerson}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="联系信息：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditingFactory.ContactInfo}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="联系方式：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding EditingFactory.ContactMethod}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="工厂规模：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditingFactory.Scale}"/>
                    <TextBlock Grid.Row="5" Grid.Column="2" Text="员工人数：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding EditingFactory.EmployeeCount}"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="生产能力：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding EditingFactory.ProductionCapacity}"/>
                    <TextBlock Grid.Row="7" Grid.Column="2" Text="负责人：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="7" Grid.Column="3" Text="{Binding EditingFactory.ControllingPerson}"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="备注：" VerticalAlignment="Top"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3"
                             Text="{Binding EditingFactory.Description}"
                             AcceptsReturn="True" Height="50"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Content="取消" Margin="0,0,10,0" Padding="15,5"
                            Command="{Binding CancelCommand}"
                            Background="Transparent" BorderThickness="1" BorderBrush="#DDDDDD"/>
                    <Button Content="保存"
                            Command="{Binding SaveFactoryCommand}"
                            Background="#4CAF50" Foreground="White" BorderThickness="0" Padding="15,5"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:DialogHost>
    </Grid>
</UserControl>