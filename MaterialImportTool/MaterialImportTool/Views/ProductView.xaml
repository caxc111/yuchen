<UserControl x:Class="MaterialImportTool.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid Background="#FFF5E6D3">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="White" Margin="0,0,0,10">
            <Button DockPanel.Dock="Left" Background="Transparent" BorderThickness="0" Padding="10"
                    Click="BackButton_Click">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" Foreground="#333333"/>
            </Button>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <materialDesign:PackIcon Kind="Package" Width="28" Height="28" Foreground="#2196F3"/>
                <TextBlock Text="添加物料" FontSize="24" Margin="10,0,0,0" Foreground="#333333"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,20,0">
                <Button Background="Transparent" BorderThickness="0" Padding="10"
                        Command="{Binding ExportCommand}">
                    <materialDesign:PackIcon Kind="Download" Width="24" Height="24" Foreground="#333333"/>
                </Button>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderThickness="1" BorderBrush="#DDDDDD" Margin="0,0,0,10">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ImageArea" Width="64" Height="64" Foreground="#999999"/>
                        <TextBlock Text="截图预览区" Margin="0,10,0,0" Foreground="#666666"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="White" BorderThickness="1" BorderBrush="#DDDDDD">
                    <StackPanel>
                        <TextBlock Text="识别结果列表" Margin="10,10,0,0" FontSize="14" FontWeight="Bold" Foreground="#333333"/>
                        <DataGrid ItemsSource="{Binding OcrResult}" Margin="10"
                                  AutoGenerateColumns="False" Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="字段名" Binding="{Binding FieldName}" Width="120"/>
                                <DataGridTextColumn Header="识别值" Binding="{Binding Value}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="手动编辑" Margin="10" HorizontalAlignment="Right"
                                Background="Transparent" BorderThickness="1" BorderBrush="#DDDDDD" Padding="10,5"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="截图" Width="100" Margin="5"
                            Command="{Binding ScreenshotCommand}"
                            Background="#2196F3" Foreground="White" BorderThickness="0" Padding="10,5"/>
                    <Button Content="重新识别" Width="100" Margin="5"
                            Background="#666666" Foreground="White" BorderThickness="0" Padding="10,5"/>
                    <Button Content="确认转入" Width="100" Margin="5"
                            Background="#4CAF50" Foreground="White" BorderThickness="0" Padding="10,5"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Width="250" Height="36"
                             Text="{Binding SearchText}"
                             materialDesign:HintAssist.Hint="搜索产品名称或编码"
                             />
                    <Button Content="搜索" Width="80" Margin="10,0,0,0"
                            Background="#666666" Foreground="White" BorderThickness="0" Padding="10,5"/>
                    <Button Content="新增物料" Margin="10,0,0,0"
                            Command="{Binding AddProductCommand}"
                            Background="#2196F3" Foreground="White" BorderThickness="0" Padding="10,5"/>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          Background="White" RowBackground="White" AlternatingRowBackground="#F9F9F9"
                          BorderThickness="1" BorderBrush="#DDDDDD"
                          ColumnHeaderHeight="35" RowHeight="30">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="Margin" Value="2,0,0,0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工厂产品编码" Binding="{Binding FactoryProductCode}" Width="150"/>
                        <DataGridTextColumn Header="宇辰编码" Binding="{Binding MyProductCode}" Width="150"/>
                        <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="180"/>
                        <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="100"/>
                        <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="120"/>
                        <DataGridTextColumn Header="工厂" Binding="{Binding FactoryName}" Width="120"/>
                        <DataGridTemplateColumn Header="详细信息" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Button Width="28" Height="28"
                                                Background="#F5F5F5" BorderBrush="#E0E0E0"
                                                BorderThickness="1" Padding="0" Cursor="Hand"
                                                Click="DetailsButton_Click" Tag="{Binding}">
                                            <Image Source="/Resources/Icons/icon_expand.png" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="操作" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Background="Transparent" BorderThickness="0" Padding="5">
                                            <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="#333333"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Background="Transparent" BorderThickness="0" Padding="5">
                                            <materialDesign:PackIcon Kind="Trash" Width="18" Height="18" Foreground="#F44336"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Excel批量导入" Width="150" Height="36"
                    Command="{Binding ExcelImportCommand}"
                    Background="#FF9800" Foreground="White" BorderThickness="0" Padding="10,5"/>
        </StackPanel>

        <materialDesign:DialogHost Identifier="ProductDialog" IsOpen="{Binding IsDialogOpen}">
            <StackPanel Width="700">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Package" Width="24" Height="24"/>
                    <TextBlock Text="{Binding EditingProduct.Id, Converter={StaticResource IdToTitleConverter}}"
                               FontSize="18" Margin="10,0,0,0"/>
                </StackPanel>

                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="工厂选择：" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" 
                              ItemsSource="{Binding Factories}"
                              DisplayMemberPath="FactoryName"
                              SelectedValuePath="FactoryCode"
                              SelectedValue="{Binding SelectedFactoryCode}"
                              />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="工厂产品编码：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding EditingProduct.FactoryProductCode}"
                             />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="宇辰产品编码：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditingProduct.MyProductCode}"
                             IsReadOnly="True" Background="#F5F5F5"
                             />
                    <Button Grid.Row="1" Grid.Column="2" Content="生成编码"
                            Command="{Binding GenerateCodeCommand}"
                            Background="#FF9800" Foreground="White" BorderThickness="0" Padding="10,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="产品名称：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding EditingProduct.ProductName}"
                             />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="品牌：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditingProduct.Brand}"
                             />
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="规格：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding EditingProduct.Specification}"
                             />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="材质：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditingProduct.Texture}"
                             />
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="工艺：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding EditingProduct.Process}"
                             />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="分类：" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="5" Grid.Column="1"
                              ItemsSource="{Binding CategoryCodes}"
                              SelectedItem="{Binding EditingProduct.Category}"
                              SelectionChanged="Category_SelectionChanged"
                              />
                    <TextBlock Grid.Row="5" Grid.Column="2" Text="二级分类：" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="5" Grid.Column="3"
                              ItemsSource="{Binding SubCategoryCodes}"
                              SelectedItem="{Binding EditingProduct.SubCategory}"
                              />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="使用场景：" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="6" Grid.Column="1">
                        <ComboBoxItem Content="客厅"/>
                        <ComboBoxItem Content="卧室"/>
                        <ComboBoxItem Content="厨房"/>
                        <ComboBoxItem Content="卫生间"/>
                        <ComboBoxItem Content="阳台"/>
                        <ComboBoxItem Content="走廊"/>
                        <ComboBoxItem Content="其他"/>
                    </ComboBox>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="认证情况：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding EditingProduct.Certifications}"
                             />

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="图片：" VerticalAlignment="Center"/>
                    <Button Grid.Row="7" Grid.Column="1" Content="选择图片"
                            Background="Transparent" BorderThickness="1" BorderBrush="#DDDDDD" Padding="10,5"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Content="取消" Margin="0,0,10,0" Padding="15,5"
                            Command="{Binding CancelCommand}"
                            Background="Transparent" BorderThickness="1" BorderBrush="#DDDDDD"/>
                    <Button Content="保存"
                            Command="{Binding SaveProductCommand}"
                            Background="#2196F3" Foreground="White" BorderThickness="0" Padding="15,5"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:DialogHost>

        <materialDesign:DialogHost Identifier="ExcelImportDialog" IsOpen="{Binding IsExcelImportOpen}">
            <StackPanel Width="600">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileExcel" Width="24" Height="24"/>
                    <TextBlock Text="Excel批量导入" FontSize="18" Margin="10,0,0,0"/>
                </StackPanel>

                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="工厂选择：" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              ItemsSource="{Binding Factories}"
                              DisplayMemberPath="FactoryName"
                              SelectedValuePath="FactoryCode"
                              SelectedValue="{Binding SelectedFactoryCode}"
                              Width="300"
                              />

                    <TextBlock Grid.Row="1" Text="Excel文件：" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                        <Button Content="选择文件" Width="120"
                                Command="{Binding BatchImportCommand}"
                                Background="#FF9800" Foreground="White" BorderThickness="0" Padding="10,5"/>
                    </StackPanel>

                    <Border Grid.Row="2" Background="White" BorderThickness="1" BorderBrush="#DDDDDD">
                        <TextBlock Text="数据预览区域（选择文件后显示）" Margin="10" Foreground="#666666"/>
                    </Border>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Content="取消" Margin="0,0,10,0" Padding="15,5"
                            Command="{Binding CancelCommand}"
                            Background="Transparent" BorderThickness="1" BorderBrush="#DDDDDD"/>
                    <Button Content="批量导入"
                            Command="{Binding BatchImportCommand}"
                            Background="#FF9800" Foreground="White" BorderThickness="0" Padding="15,5"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:DialogHost>
    </Grid>
</UserControl>