<UserControl x:Class="MaterialImportTool.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid Background="#FFF5E6D3">
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="宇辰物料采集导入工具" 
                   FontSize="32" FontFamily="微软雅黑" 
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#333333"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Margin="80,40,40,40"
                    Click="FactoryButton_Click"
                    Style="{StaticResource HomeCardButton}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Building" Width="64" Height="64" Foreground="#4CAF50"/>
                    <TextBlock Text="添加工厂" FontSize="24" Margin="0,20,0,0" Foreground="#333333"/>
                    <TextBlock Text="管理工厂信息" FontSize="14" Margin="0,10,0,0" Foreground="#666666"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="1" Margin="40,40,80,40"
                    Click="ProductButton_Click"
                    Style="{StaticResource HomeCardButton}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Package" Width="64" Height="64" Foreground="#2196F3"/>
                    <TextBlock Text="添加物料" FontSize="24" Margin="0,20,0,0" Foreground="#333333"/>
                    <TextBlock Text="截图识别/手动添加" FontSize="14" Margin="0,10,0,0" Foreground="#666666"/>
                </StackPanel>
            </Button>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,0,0,20">
            <Button Background="Transparent" BorderThickness="0"
                    Click="SettingsButton_Click" Padding="10">
                <materialDesign:PackIcon Kind="Settings" Width="24" Height="24" Foreground="#666666"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>